#!/bin/sh

set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
TMP_BASE=${TMPDIR:-/tmp}
E2E_ROOT=$(mktemp -d "$TMP_BASE/agent-meong-e2e.XXXXXX")
E2E_HOME="$E2E_ROOT/home"
INSTALLED_ADAPTER="$E2E_HOME/Library/Application Support/AgentMeong/codex_hook.py"
SOCKET="$E2E_ROOT/events.sock"
REPORT="$E2E_ROOT/report.jsonl"
LOG="$E2E_ROOT/app.log"
SECOND_REPORT="$E2E_ROOT/second-report.jsonl"
SECOND_LOG="$E2E_ROOT/second-app.log"
RELAUNCH_REPORT="$E2E_ROOT/relaunch-report.jsonl"
RELAUNCH_LOG="$E2E_ROOT/relaunch-app.log"
RACE_SOCKET="$E2E_ROOT/startup-race.sock"
RACE_A_REPORT="$E2E_ROOT/race-a-report.jsonl"
RACE_A_LOG="$E2E_ROOT/race-a.log"
RACE_B_REPORT="$E2E_ROOT/race-b-report.jsonl"
RACE_B_LOG="$E2E_ROOT/race-b.log"
APP="$ROOT/dist/AgentMeong.app"
APP_PID=
SECOND_APP_PID=
RELAUNCH_APP_PID=
RACE_A_PID=
RACE_B_PID=

cleanup() {
    if [ -n "$APP_PID" ]; then
        kill "$APP_PID" 2>/dev/null || true
        wait "$APP_PID" 2>/dev/null || true
    fi
    if [ -n "$SECOND_APP_PID" ]; then
        kill "$SECOND_APP_PID" 2>/dev/null || true
        wait "$SECOND_APP_PID" 2>/dev/null || true
    fi
    if [ -n "$RELAUNCH_APP_PID" ]; then
        kill "$RELAUNCH_APP_PID" 2>/dev/null || true
        wait "$RELAUNCH_APP_PID" 2>/dev/null || true
    fi
    if [ -n "$RACE_A_PID" ]; then
        kill "$RACE_A_PID" 2>/dev/null || true
        wait "$RACE_A_PID" 2>/dev/null || true
    fi
    if [ -n "$RACE_B_PID" ]; then
        kill "$RACE_B_PID" 2>/dev/null || true
        wait "$RACE_B_PID" 2>/dev/null || true
    fi
    rm -rf "$E2E_ROOT"
}
trap cleanup EXIT INT TERM

wait_for_event() {
    wait_for_event_in "$REPORT" "$LOG" "$1"
}

wait_for_event_in() {
    report_path=$1
    log_path=$2
    event=$3
    attempts=0
    while [ "$attempts" -lt 100 ]; do
        if [ -f "$report_path" ] && grep -F "\"event\":\"$event\"" "$report_path" >/dev/null; then
            return 0
        fi
        attempts=$((attempts + 1))
        sleep 0.1
    done
    echo "Timed out waiting for $event" >&2
    if [ -f "$log_path" ]; then
        sed -n '1,120p' "$log_path" >&2
    fi
    return 1
}

send_until_observed() {
    payload=$1
    attempts=0
    while [ "$attempts" -lt 20 ]; do
        printf '%s\n' "$payload" | \
            env AGENT_MEONG_SOCKET="$SOCKET" /usr/bin/python3 "$INSTALLED_ADAPTER"
        if [ -f "$REPORT" ] && grep -F '"event":"observation"' "$REPORT" >/dev/null; then
            return 0
        fi
        attempts=$((attempts + 1))
        sleep 0.1
    done
    echo "Timed out sending the first observation" >&2
    if [ -f "$LOG" ]; then
        sed -n '1,120p' "$LOG" >&2
    fi
    return 1
}

bash "$ROOT/scripts/package-app" >/dev/null
mkdir -p "$E2E_HOME"
HOME="$E2E_HOME" /usr/bin/python3 \
    "$APP/Contents/Resources/codex_hook.py" --install | grep -F '"status": "installed"' >/dev/null
test -f "$E2E_HOME/.codex/hooks.json"
test -f "$INSTALLED_ADAPTER"

env \
    HOME="$E2E_HOME" \
    AGENT_MEONG_DEBUG_DOCK=1 \
    AGENT_MEONG_E2E_REPORT="$REPORT" \
    AGENT_MEONG_SOCKET="$SOCKET" \
    "$APP/Contents/MacOS/AgentMeong" >"$LOG" 2>&1 &
APP_PID=$!

wait_for_event launched
wait_for_event hook_status
wait_for_event popover_opened
wait_for_event popover_active

env \
    HOME="$E2E_HOME" \
    AGENT_MEONG_E2E_SUPPRESS_OPEN=1 \
    AGENT_MEONG_E2E_REPORT="$SECOND_REPORT" \
    AGENT_MEONG_SOCKET="$SOCKET" \
    "$APP/Contents/MacOS/AgentMeong" >"$SECOND_LOG" 2>&1 &
SECOND_APP_PID=$!
wait_for_event_in "$SECOND_REPORT" "$SECOND_LOG" launched
/usr/bin/python3 -c '
import json
import sys

records = [json.loads(line) for line in open(sys.argv[1], encoding="utf-8") if line.strip()]
if not any(record.get("event") == "launched" and not record.get("receiverReady") for record in records):
    raise SystemExit("Second app instance unexpectedly replaced the live socket")
' "$SECOND_REPORT"
kill "$SECOND_APP_PID"
wait "$SECOND_APP_PID" 2>/dev/null || true
SECOND_APP_PID=

send_until_observed '{"hook_event_name":"UserPromptSubmit","session_id":"e2e-session-a","turn_id":"e2e-turn-a"}'
printf '%s\n' '{"hook_event_name":"UserPromptSubmit","session_id":"e2e-session-b","turn_id":"e2e-turn-b"}' | \
    env AGENT_MEONG_SOCKET="$SOCKET" /usr/bin/python3 "$INSTALLED_ADAPTER"
printf '%s\n' '{"hook_event_name":"SubagentStart","session_id":"e2e-session-b","turn_id":"e2e-turn-b","agent_id":"e2e-child"}' | \
    env AGENT_MEONG_SOCKET="$SOCKET" /usr/bin/python3 "$INSTALLED_ADAPTER"
printf '%s\n' '{"hook_event_name":"SubagentStop","session_id":"e2e-session-b","turn_id":"e2e-turn-b","agent_id":"e2e-child","outcome":"success"}' | \
    env AGENT_MEONG_SOCKET="$SOCKET" /usr/bin/python3 "$INSTALLED_ADAPTER"
printf '%s\n' '{"hook_event_name":"Stop","session_id":"e2e-session-a","turn_id":"e2e-turn-a","outcome":"success"}' | \
    env AGENT_MEONG_SOCKET="$SOCKET" /usr/bin/python3 "$INSTALLED_ADAPTER"
printf '%s\n' '{"hook_event_name":"Stop","session_id":"e2e-session-b","turn_id":"e2e-turn-b","outcome":"success"}' | \
    env AGENT_MEONG_SOCKET="$SOCKET" /usr/bin/python3 "$INSTALLED_ADAPTER"

/usr/bin/osascript -e 'tell application "Finder" to activate'
wait_for_event popover_closed

printf '%s\n' '{"hook_event_name":"UserPromptSubmit","session_id":"e2e-session-c","turn_id":"e2e-turn-c"}' | \
    env AGENT_MEONG_SOCKET="$SOCKET" /usr/bin/python3 "$INSTALLED_ADAPTER"
printf '%s\n' '{"hook_event_name":"Stop","session_id":"e2e-session-c","turn_id":"e2e-turn-c","outcome":"success"}' | \
    env AGENT_MEONG_SOCKET="$SOCKET" /usr/bin/python3 "$INSTALLED_ADAPTER"

/usr/bin/python3 -c '
import json
import sys
import time

path = sys.argv[1]
deadline = time.time() + 10
records = []
while time.time() < deadline:
    with open(path, encoding="utf-8") as handle:
        records = [json.loads(line) for line in handle if line.strip()]
    observations = [record for record in records if record.get("event") == "observation"]
    completed_while_hidden = any(
        record.get("completionUnseen") is True
        and record.get("aggregateState") == "completed"
        and record.get("liveActorCount") == 0
        for record in observations
    )
    if len(observations) >= 8 and completed_while_hidden:
        break
    time.sleep(0.1)
else:
    raise SystemExit("Timed out waiting for completed observation")

allowed = {
    "activeActorCount",
    "aggregateState",
    "childAbsorptions",
    "childBirths",
    "completionNotified",
    "completionUnseen",
    "connectionGuidanceVisible",
    "event",
    "hookInstalled",
    "liveActorCount",
    "onboardingNeeded",
    "popoverBehavior",
    "receiverReady",
}
if any(set(record) - allowed for record in records):
    raise SystemExit("E2E report contains fields outside the privacy allowlist")
if not any(record.get("event") == "launched" and record.get("receiverReady") for record in records):
    raise SystemExit("Packaged app receiver did not start")
if not any(record.get("event") == "hook_status" and record.get("hookInstalled") for record in records):
    raise SystemExit("Packaged app did not detect the isolated user hook installation")
if not any(
    record.get("event") == "hook_status"
    and record.get("onboardingNeeded") is True
    and record.get("connectionGuidanceVisible") is True
    for record in records
):
    raise SystemExit("First unconfirmed connection did not show onboarding guidance")
if not any(record.get("event") == "launched" and record.get("popoverBehavior") == "transient" for record in records):
    raise SystemExit("Packaged app popover is not transient")
if not any(record.get("event") == "popover_closed" for record in records):
    raise SystemExit("Popover close delegate did not run")
if observations[0].get("aggregateState") != "active" or observations[0].get("liveActorCount") != 1:
    raise SystemExit("Start hook did not create one active logical actor")
if not any(record.get("childBirths") == 1 for record in observations):
    raise SystemExit("Subagent start did not schedule one child birth")
if not any(record.get("childAbsorptions") == 1 for record in observations):
    raise SystemExit("Subagent stop did not schedule one child absorption")
if not any(
    record.get("completionNotified") is True
    and record.get("completionUnseen") is False
    and record.get("aggregateState") == "active"
    and record.get("activeActorCount") == 1
    for record in observations
):
    raise SystemExit("Partial top-level completion did not notify while other work stayed active")
child_completion = next(
    (record for record in observations if record.get("childAbsorptions") == 1),
    None,
)
if child_completion is None or child_completion.get("completionNotified") is not False:
    raise SystemExit("Subagent completion incorrectly triggered the menu completion signal")
if not any(record.get("completionUnseen") is True for record in observations):
    raise SystemExit("Completion while the popover was closed did not remain visible")
if observations[-1].get("aggregateState") != "completed" or observations[-1].get("liveActorCount") != 0:
    raise SystemExit("Stop hook did not complete the logical actor")
' "$REPORT"

kill "$APP_PID"
wait "$APP_PID" 2>/dev/null || true
APP_PID=
env \
    HOME="$E2E_HOME" \
    AGENT_MEONG_E2E_PREVIOUSLY_CONFIRMED=1 \
    AGENT_MEONG_E2E_REPORT="$RELAUNCH_REPORT" \
    AGENT_MEONG_SOCKET="$SOCKET" \
    "$APP/Contents/MacOS/AgentMeong" >"$RELAUNCH_LOG" 2>&1 &
RELAUNCH_APP_PID=$!
wait_for_event_in "$RELAUNCH_REPORT" "$RELAUNCH_LOG" hook_status
/usr/bin/python3 -c '
import json
import sys

records = [json.loads(line) for line in open(sys.argv[1], encoding="utf-8") if line.strip()]
status = next((record for record in records if record.get("event") == "hook_status"), None)
if status is None or status.get("hookInstalled") is not True:
    raise SystemExit("Relaunched app did not retain the installed hook")
if status.get("onboardingNeeded") is not False:
    raise SystemExit("Previously confirmed connection reopened onboarding")
if status.get("connectionGuidanceVisible") is not False:
    raise SystemExit("Previously confirmed connection obscured Meong Space")
' "$RELAUNCH_REPORT"

kill "$RELAUNCH_APP_PID"
wait "$RELAUNCH_APP_PID" 2>/dev/null || true
RELAUNCH_APP_PID=
env \
    HOME="$E2E_HOME" \
    AGENT_MEONG_E2E_SUPPRESS_OPEN=1 \
    AGENT_MEONG_E2E_REPORT="$RACE_A_REPORT" \
    AGENT_MEONG_SOCKET="$RACE_SOCKET" \
    "$APP/Contents/MacOS/AgentMeong" >"$RACE_A_LOG" 2>&1 &
RACE_A_PID=$!
env \
    HOME="$E2E_HOME" \
    AGENT_MEONG_E2E_SUPPRESS_OPEN=1 \
    AGENT_MEONG_E2E_REPORT="$RACE_B_REPORT" \
    AGENT_MEONG_SOCKET="$RACE_SOCKET" \
    "$APP/Contents/MacOS/AgentMeong" >"$RACE_B_LOG" 2>&1 &
RACE_B_PID=$!
wait_for_event_in "$RACE_A_REPORT" "$RACE_A_LOG" launched
wait_for_event_in "$RACE_B_REPORT" "$RACE_B_LOG" launched
/usr/bin/python3 -c '
import json
import sys

states = []
for path in sys.argv[1:]:
    records = [json.loads(line) for line in open(path, encoding="utf-8") if line.strip()]
    launched = next(record for record in records if record.get("event") == "launched")
    states.append(launched.get("receiverReady"))
if sorted(states) != [False, True]:
    raise SystemExit("Concurrent startup did not elect exactly one socket owner")
' "$RACE_A_REPORT" "$RACE_B_REPORT"
kill "$RACE_A_PID"
kill "$RACE_B_PID"
wait "$RACE_A_PID" 2>/dev/null || true
wait "$RACE_B_PID" 2>/dev/null || true
RACE_A_PID=
RACE_B_PID=

/usr/bin/python3 -c '
import json
import sys

allowed_events = {
    "hook_status",
    "launched",
    "observation",
    "popover_active",
    "popover_closed",
    "popover_opened",
}
allowed_fields = {
    "activeActorCount",
    "aggregateState",
    "childAbsorptions",
    "childBirths",
    "completionNotified",
    "completionUnseen",
    "connectionGuidanceVisible",
    "event",
    "hookInstalled",
    "liveActorCount",
    "onboardingNeeded",
    "popoverBehavior",
    "receiverReady",
}
for path in sys.argv[1:]:
    records = [json.loads(line) for line in open(path, encoding="utf-8") if line.strip()]
    if any(record.get("event") not in allowed_events for record in records):
        raise SystemExit(f"E2E report emitted an event outside the privacy allowlist: {path}")
    if any(set(record) - allowed_fields for record in records):
        raise SystemExit(f"E2E report emitted fields outside the privacy allowlist: {path}")
' "$REPORT" "$SECOND_REPORT" "$RELAUNCH_REPORT" "$RACE_A_REPORT" "$RACE_B_REPORT"

echo "agent-meong E2E: hook, socket, UI lifecycle, and privacy report passed"
