#!/bin/sh

set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
TMP_BASE=${TMPDIR:-/tmp}
E2E_ROOT=$(mktemp -d "$TMP_BASE/agent-meong-e2e.XXXXXX")
E2E_ROOT=$(CDPATH= cd -- "$E2E_ROOT" && pwd -P)
E2E_HOME="$E2E_ROOT/home"
INSTALLED_ADAPTER_ROOT="$E2E_HOME/Library/Application Support/AgentMeong/codex-hooks"
SOCKET="$E2E_ROOT/events.sock"
REPORT="$E2E_ROOT/report.jsonl"
LOG="$E2E_ROOT/app.log"
SECOND_REPORT="$E2E_ROOT/second-report.jsonl"
SECOND_LOG="$E2E_ROOT/second-app.log"
RELAUNCH_REPORT="$E2E_ROOT/relaunch-report.jsonl"
RELAUNCH_LOG="$E2E_ROOT/relaunch-app.log"
RACE_SOCKET="$E2E_ROOT/startup-race.sock"
RACE_A_REPORT="$E2E_ROOT/race-a-report.jsonl"
RACE_A_LOG="$E2E_ROOT/race-a.log"
RACE_B_REPORT="$E2E_ROOT/race-b-report.jsonl"
RACE_B_LOG="$E2E_ROOT/race-b.log"
DISABLED_REPORT="$E2E_ROOT/disabled-report.jsonl"
DISABLED_LOG="$E2E_ROOT/disabled.log"
MANAGED_REPORT="$E2E_ROOT/managed-report.jsonl"
MANAGED_LOG="$E2E_ROOT/managed.log"
INLINE_REPORT="$E2E_ROOT/inline-report.jsonl"
INLINE_LOG="$E2E_ROOT/inline.log"
LONG_GUIDANCE_REPORT="$E2E_ROOT/long-guidance-report.jsonl"
LONG_GUIDANCE_LOG="$E2E_ROOT/long-guidance.log"
TRUST_STATE_REPORT="$E2E_ROOT/trust-state-report.jsonl"
TRUST_STATE_LOG="$E2E_ROOT/trust-state.log"
CUSTOM_REPORT="$E2E_ROOT/custom-report.jsonl"
CUSTOM_LOG="$E2E_ROOT/custom.log"
CUSTOM_RELAUNCH_REPORT="$E2E_ROOT/custom-relaunch-report.jsonl"
CUSTOM_RELAUNCH_LOG="$E2E_ROOT/custom-relaunch.log"
CUSTOM_CLEARED_REPORT="$E2E_ROOT/custom-cleared-report.jsonl"
CUSTOM_CLEARED_LOG="$E2E_ROOT/custom-cleared.log"
CONFIRMATION_SUITE="dev.ailab.agent-meong.e2e.$$"
LEGEND_SUITE="dev.ailab.agent-meong.legend.e2e.$$"
REDUCE_MOTION_SUITE="dev.ailab.agent-meong.reduce-motion.e2e.$$"
CLOSING_SUITE="dev.ailab.agent-meong.closing.e2e.$$"
CONNECT_HOME="$E2E_ROOT/connect-home"
CONNECT_WRONG_HOME="$E2E_ROOT/connect-wrong-codex-home"
CONNECT_REPORT="$E2E_ROOT/connect-report.jsonl"
CONNECT_LOG="$E2E_ROOT/connect.log"
CONNECT_TRUST_STATE="$E2E_ROOT/connect-trust-state"
UNAVAILABLE_OPENED_REPORT="$E2E_ROOT/unavailable-opened-report.jsonl"
UNAVAILABLE_OPENED_LOG="$E2E_ROOT/unavailable-opened.log"
UNAVAILABLE_FAILED_REPORT="$E2E_ROOT/unavailable-failed-report.jsonl"
UNAVAILABLE_FAILED_LOG="$E2E_ROOT/unavailable-failed.log"
KOREAN_REPORT="$E2E_ROOT/korean-report.jsonl"
KOREAN_LOG="$E2E_ROOT/korean.log"
ENGLISH_REPORT="$E2E_ROOT/english-report.jsonl"
ENGLISH_LOG="$E2E_ROOT/english.log"
REDUCE_MOTION_REPORT="$E2E_ROOT/reduce-motion-report.jsonl"
REDUCE_MOTION_LOG="$E2E_ROOT/reduce-motion.log"
CLOSING_REPORT="$E2E_ROOT/closing-report.jsonl"
CLOSING_LOG="$E2E_ROOT/closing.log"
REPAIR_REPORT="$E2E_ROOT/repair-report.jsonl"
REPAIR_LOG="$E2E_ROOT/repair.log"
FORGET_MIXED_REPORT="$E2E_ROOT/forget-mixed-report.jsonl"
FORGET_MIXED_LOG="$E2E_ROOT/forget-mixed.log"
REMOVAL_REPORT="$E2E_ROOT/removal-report.jsonl"
REMOVAL_LOG="$E2E_ROOT/removal.log"
REMOVAL_REVERSE_REPORT="$E2E_ROOT/removal-reverse-report.jsonl"
REMOVAL_REVERSE_LOG="$E2E_ROOT/removal-reverse.log"
PACKAGED_APP="$ROOT/dist/AgentMeong.app"
APP="$E2E_ROOT/AgentMeong.app"
APP_EXECUTABLE="$APP/Contents/MacOS/AgentMeong"
FAKE_CODEX="$E2E_ROOT/fake-codex"
FAKE_CODEX_PHASES="$E2E_ROOT/fake-codex-phases"
APP_PID=
APP_LAUNCHER_PID=
SECOND_APP_PID=
RELAUNCH_APP_PID=
RACE_A_PID=
RACE_B_PID=
STATUS_PID=
SEND_SEQUENCE=0

is_e2e_app_pid() {
    pid=$1
    case "$pid" in
        ''|*[!0-9]*) return 1 ;;
    esac
    command=$(/bin/ps -p "$pid" -o command= 2>/dev/null || true)
    case "$command" in
        "$APP_EXECUTABLE"|"$APP_EXECUTABLE "*) return 0 ;;
    esac
    return 1
}

stop_e2e_app_pid() {
    pid=$1
    if is_e2e_app_pid "$pid"; then
        /bin/kill -TERM "$pid" 2>/dev/null || true
    fi
    attempts=0
    while is_e2e_app_pid "$pid" && [ "$attempts" -lt 50 ]; do
        attempts=$((attempts + 1))
        sleep 0.1
    done
    if is_e2e_app_pid "$pid"; then
        /bin/kill -KILL "$pid" 2>/dev/null || true
    fi
    wait "$pid" 2>/dev/null || true
}

e2e_app_pids() {
    /usr/bin/pgrep -x AgentMeong 2>/dev/null | while IFS= read -r pid; do
        if is_e2e_app_pid "$pid"; then
            printf '%s\n' "$pid"
        fi
    done
}

cleanup() {
    if [ -n "$APP_PID" ]; then
        stop_e2e_app_pid "$APP_PID"
    fi
    if [ -n "$SECOND_APP_PID" ]; then
        stop_e2e_app_pid "$SECOND_APP_PID"
    fi
    if [ -n "$RELAUNCH_APP_PID" ]; then
        stop_e2e_app_pid "$RELAUNCH_APP_PID"
    fi
    if [ -n "$RACE_A_PID" ]; then
        stop_e2e_app_pid "$RACE_A_PID"
    fi
    if [ -n "$RACE_B_PID" ]; then
        stop_e2e_app_pid "$RACE_B_PID"
    fi
    if [ -n "$STATUS_PID" ]; then
        stop_e2e_app_pid "$STATUS_PID"
    fi
    for pid in $(e2e_app_pids); do
        stop_e2e_app_pid "$pid"
    done
    if [ -n "$APP_LAUNCHER_PID" ]; then
        launcher_command=$(/bin/ps -p "$APP_LAUNCHER_PID" -o command= 2>/dev/null || true)
        case "$launcher_command" in
            "/usr/bin/open -n -W "*"$APP")
                /bin/kill -TERM "$APP_LAUNCHER_PID" 2>/dev/null || true
                attempts=0
                while /bin/kill -0 "$APP_LAUNCHER_PID" 2>/dev/null \
                    && [ "$attempts" -lt 50 ]
                do
                    attempts=$((attempts + 1))
                    sleep 0.1
                done
                if /bin/kill -0 "$APP_LAUNCHER_PID" 2>/dev/null; then
                    /bin/kill -KILL "$APP_LAUNCHER_PID" 2>/dev/null || true
                fi
                ;;
        esac
        wait "$APP_LAUNCHER_PID" 2>/dev/null || true
    fi
    /usr/bin/defaults delete "$CONFIRMATION_SUITE" 2>/dev/null || true
    /usr/bin/defaults delete "$LEGEND_SUITE" 2>/dev/null || true
    /usr/bin/defaults delete "$REDUCE_MOTION_SUITE" 2>/dev/null || true
    /usr/bin/defaults delete "$CLOSING_SUITE" 2>/dev/null || true
    rm -rf "$E2E_ROOT"
}
trap cleanup EXIT INT TERM

wait_for_event() {
    wait_for_event_in "$REPORT" "$LOG" "$1"
}

wait_for_event_count() {
    report_path=$1
    log_path=$2
    event=$3
    expected_count=$4
    maximum_attempts=${5:-100}
    attempts=0
    while [ "$attempts" -lt "$maximum_attempts" ]; do
        count=0
        if [ -f "$report_path" ]; then
            count=$(grep -c -F "\"event\":\"$event\"" "$report_path" || true)
        fi
        if [ "$count" -ge "$expected_count" ]; then
            return 0
        fi
        attempts=$((attempts + 1))
        sleep 0.1
    done
    echo "Timed out waiting for $event count $expected_count" >&2
    if [ -f "$report_path" ]; then
        tail -n 60 "$report_path" >&2
    fi
    if [ -f "$log_path" ]; then
        sed -n '1,120p' "$log_path" >&2
    fi
    return 1
}

wait_for_event_in() {
    report_path=$1
    log_path=$2
    event=$3
    attempts=0
    while [ "$attempts" -lt 100 ]; do
        if [ -f "$report_path" ] && grep -F "\"event\":\"$event\"" "$report_path" >/dev/null; then
            return 0
        fi
        attempts=$((attempts + 1))
        sleep 0.1
    done
    echo "Timed out waiting for $event" >&2
    if [ -f "$report_path" ]; then
        tail -n 60 "$report_path" >&2
    fi
    if [ -f "$log_path" ]; then
        sed -n '1,120p' "$log_path" >&2
    fi
    return 1
}

send_until_observed() {
    payload=$1
    send_observation "$SOCKET" "$INSTALLED_ADAPTER" "$payload"
    attempts=0
    while [ "$attempts" -lt 20 ]; do
        if [ -f "$REPORT" ] && grep -F '"event":"observation"' "$REPORT" >/dev/null; then
            return 0
        fi
        attempts=$((attempts + 1))
        sleep 0.1
    done
    echo "Timed out sending the first observation" >&2
    if [ -f "$REPORT" ]; then
        tail -n 50 "$REPORT" >&2
    fi
    if [ -f "$LOG" ]; then
        sed -n '1,120p' "$LOG" >&2
    fi
    return 1
}

send_observation() {
    socket_path=$1
    forwarder_path=$2
    payload=$3
    SEND_SEQUENCE=$((SEND_SEQUENCE + 1))
    attempts=0
    while [ "$attempts" -lt 20 ]; do
        if printf '%s\n' "$payload" | env \
            AGENT_MEONG_E2E_DELIVERY_DIAGNOSTICS=1 \
            AGENT_MEONG_E2E_REQUIRE_DELIVERY=1 \
            AGENT_MEONG_SOCKET="$socket_path" \
            "$forwarder_path"
        then
            return 0
        fi
        attempts=$((attempts + 1))
        sleep 0.05
    done
    SOCKET_PRESENT=false
    PRIMARY_ALIVE=false
    [ -S "$socket_path" ] && SOCKET_PRESENT=true
    if [ -n "$APP_PID" ] && is_e2e_app_pid "$APP_PID"; then
        PRIMARY_ALIVE=true
    fi
    echo "Timed out delivering observation $SEND_SEQUENCE to $socket_path" >&2
    echo "socketPresent=$SOCKET_PRESENT primaryAlive=$PRIMARY_ALIVE" >&2
    return 1
}

send_observation_without_owner() {
    socket_path=$1
    forwarder_path=$2
    payload=$3
    attempts=0
    while [ "$attempts" -lt 20 ]; do
        if printf '%s\n' "$payload" \
            | "$forwarder_path" --print \
            | /usr/bin/python3 -c '
import json
import socket
import sys

observation = json.load(sys.stdin)
observation.pop("integrationInstance", None)
client = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
try:
    client.connect(sys.argv[1])
    client.sendall((json.dumps(observation) + "\n").encode("utf-8"))
finally:
    client.close()
' "$socket_path"
        then
            return 0
        fi
        attempts=$((attempts + 1))
        sleep 0.05
    done
    echo "Timed out delivering owner-less observation to $socket_path" >&2
    return 1
}

bash "$ROOT/scripts/package-app" >/dev/null
/usr/bin/ditto "$PACKAGED_APP" "$APP"
test -x "$APP/Contents/Helpers/codex_hook_forwarder"
/usr/bin/codesign --verify --strict "$APP/Contents/Helpers/codex_hook_forwarder"
REVIEW_LAUNCHER="$APP/Contents/Resources/open-codex-hook-review.command"
test -x "$REVIEW_LAUNCHER"
if grep -F -- '--dangerously-bypass-hook-trust' "$REVIEW_LAUNCHER" >/dev/null \
    || grep -F -- 'exec /hooks' "$REVIEW_LAUNCHER" >/dev/null
then
    echo "Codex review launcher bypasses trust or sends /hooks as a prompt" >&2
    exit 1
fi
cat >"$FAKE_CODEX" <<'PY'
#!/usr/bin/python3

import hashlib
import json
import os
import pathlib
import sys


EVENT_NAMES = {
    "UserPromptSubmit": "userPromptSubmit",
    "PreToolUse": "preToolUse",
    "PermissionRequest": "permissionRequest",
    "PostToolUse": "postToolUse",
    "SubagentStart": "subagentStart",
    "SubagentStop": "subagentStop",
    "Stop": "stop",
}


def hook_metadata(codex_home):
    hooks_path = (codex_home / "hooks.json").resolve()
    try:
        document = json.loads(hooks_path.read_text(encoding="utf-8"))
    except (OSError, ValueError):
        return []

    trust_status = os.environ.get(
        "AGENT_MEONG_E2E_HOOK_RUNTIME_TRUST", "trusted"
    )
    trust_state_path = os.environ.get("AGENT_MEONG_E2E_HOOK_RUNTIME_TRUST_FILE")
    if trust_state_path:
        try:
            trust_status = pathlib.Path(trust_state_path).read_text(
                encoding="utf-8"
            ).strip()
        except OSError:
            pass
    disabled_events = {
        value.strip()
        for value in os.environ.get(
            "AGENT_MEONG_E2E_HOOK_RUNTIME_DISABLED", ""
        ).split(",")
        if value.strip()
    }
    hooks = []
    for event_name, runtime_name in EVENT_NAMES.items():
        groups = document.get("hooks", {}).get(event_name, [])
        if not isinstance(groups, list):
            continue
        for group_index, group in enumerate(groups):
            if not isinstance(group, dict):
                continue
            matcher = group.get("matcher")
            if not isinstance(matcher, str):
                matcher = None
            handlers = group.get("hooks", [])
            if not isinstance(handlers, list):
                continue
            for handler_index, handler in enumerate(handlers):
                if not isinstance(handler, dict) or handler.get("type") != "command":
                    continue
                definition = json.dumps(
                    [event_name, group_index, handler_index, handler],
                    sort_keys=True,
                    separators=(",", ":"),
                ).encode("utf-8")
                digest = hashlib.sha256(definition).hexdigest()
                hooks.append({
                    "key": "agent-meong-e2e-" + digest[:16],
                    "eventName": runtime_name,
                    "handlerType": "command",
                    "matcher": matcher,
                    "command": handler.get("command"),
                    "timeoutSec": handler.get("timeout"),
                    "statusMessage": handler.get("statusMessage"),
                    "sourcePath": str(hooks_path),
                    "source": "user",
                    "pluginId": None,
                    "displayOrder": len(hooks),
                    "enabled": (
                        event_name not in disabled_events
                        and runtime_name not in disabled_events
                    ),
                    "isManaged": False,
                    "currentHash": "sha256:" + digest,
                    "trustStatus": trust_status,
                })
    return hooks


arguments = sys.argv[1:]
if (
    not arguments
    or arguments[0] != "app-server"
    or "analytics.enabled=false" not in arguments
    or arguments[-2:] != ["--listen", "stdio://"]
):
    raise SystemExit(2)
log_arguments = [value for value in arguments if value.startswith("log_dir=")]
if len(log_arguments) != 1:
    raise SystemExit("runtime diagnostics did not isolate Codex logs")
log_home = pathlib.Path(json.loads(log_arguments[0].split("=", 1)[1]))
sqlite_home = pathlib.Path(os.environ["CODEX_SQLITE_HOME"])
if (
    not log_home.is_dir()
    or not sqlite_home.is_dir()
    or (log_home.stat().st_mode & 0o777) != 0o700
    or (sqlite_home.stat().st_mode & 0o777) != 0o700
):
    raise SystemExit("runtime diagnostics did not isolate Codex state")
codex_home = pathlib.Path(
    os.environ.get("CODEX_HOME", pathlib.Path.home() / ".codex")
).expanduser()
phase = "runtime" if (codex_home / "hooks.json").is_file() else "bootstrap"
with open(os.environ["AGENT_MEONG_E2E_CODEX_PHASES"], "a", encoding="utf-8") as handle:
    handle.write(phase + "\n")

for line in sys.stdin:
    request = json.loads(line)
    method = request.get("method")
    if method == "initialize":
        result = {"userAgent": "agent-meong-e2e"}
    elif method == "hooks/list":
        hooks = hook_metadata(codex_home)
        result = {
            "data": [
                {"cwd": cwd, "hooks": hooks, "errors": []}
                for cwd in request.get("params", {}).get("cwds", [])
            ],
            "warnings": [],
        }
    else:
        continue
    print(json.dumps({"id": request["id"], "result": result}), flush=True)
PY
chmod 700 "$FAKE_CODEX"
export AGENT_MEONG_E2E_CODEX_BIN="$FAKE_CODEX"
export AGENT_MEONG_E2E_CODEX_PHASES="$FAKE_CODEX_PHASES"
/usr/bin/defaults delete "$CONFIRMATION_SUITE" 2>/dev/null || true
/usr/bin/defaults delete "$LEGEND_SUITE" 2>/dev/null || true
mkdir -p "$CONNECT_HOME" "$CONNECT_WRONG_HOME"
printf '%s\n' untrusted >"$CONNECT_TRUST_STATE"
env \
    HOME="$CONNECT_HOME" \
    CODEX_HOME="$CONNECT_WRONG_HOME" \
    AGENT_MEONG_FORWARDER_SOURCE=/usr/bin/false \
    AGENT_MEONG_E2E_AUTO_CONNECT=1 \
    AGENT_MEONG_E2E_AUTO_CONNECT_DURING_STATUS=1 \
    AGENT_MEONG_E2E_HOOK_STATUS_RESULT_DELAY=0.35 \
    AGENT_MEONG_E2E_HOOK_RUNTIME_TRUST_FILE="$CONNECT_TRUST_STATE" \
    AGENT_MEONG_E2E_REVIEW_REFRESH_INTERVAL=0.08 \
    AGENT_MEONG_E2E_SUPPRESS_OPEN=1 \
    AGENT_MEONG_E2E_REPORT="$CONNECT_REPORT" \
    AGENT_MEONG_SOCKET="$E2E_ROOT/connect.sock" \
    "$APP/Contents/MacOS/AgentMeong" >"$CONNECT_LOG" 2>&1 &
STATUS_PID=$!
wait_for_event_in "$CONNECT_REPORT" "$CONNECT_LOG" hook_installation
attempts=0
while [ "$attempts" -lt 100 ]; do
    if [ -f "$FAKE_CODEX_PHASES" ] \
        && grep -F -x bootstrap "$FAKE_CODEX_PHASES" >/dev/null 2>&1 \
        && grep -F -x runtime "$FAKE_CODEX_PHASES" >/dev/null 2>&1
    then
        break
    fi
    attempts=$((attempts + 1))
    sleep 0.1
done
if [ "$attempts" -ge 100 ]; then
    echo "Timed out waiting for isolated Codex bootstrap and runtime probes" >&2
    exit 1
fi
test -f "$CONNECT_HOME/.codex/hooks.json"
test ! -e "$CONNECT_WRONG_HOME/hooks.json"
test "$(find "$CONNECT_HOME/Library/Application Support/AgentMeong/codex-hooks" \
    -type f -name codex_hook_forwarder | wc -l | tr -d ' ')" = "1"
/usr/bin/python3 -c '
import json
import sys

records = [json.loads(line) for line in open(sys.argv[1], encoding="utf-8") if line.strip()]
installation = next(record for record in records if record.get("event") == "hook_installation")
if installation.get("hookInstalled") is not True:
    raise SystemExit("Onboarding action did not install the user hook")
if installation.get("hooksCommandCopied") is not True:
    raise SystemExit("Installed onboarding did not copy /hooks")
if installation.get("reviewLaunchSucceeded") is not True:
    raise SystemExit("Installed onboarding did not request a fresh Codex review")
if installation.get("runtimeStatus") != "review_required":
    raise SystemExit("Onboarding fixture did not surface untrusted Codex hooks")
' "$CONNECT_REPORT"
wait_for_event_count "$CONNECT_REPORT" "$CONNECT_LOG" hook_status 4 200
printf '%s\n' trusted >"$CONNECT_TRUST_STATE"
attempts=0
while [ "$attempts" -lt 100 ]; do
    if grep -F '"runtimeStatus":"ready"' "$CONNECT_REPORT" >/dev/null 2>&1; then
        break
    fi
    attempts=$((attempts + 1))
    sleep 0.1
done
if [ "$attempts" -ge 100 ]; then
    echo "Timed out waiting for late Codex approval refresh" >&2
    tail -n 60 "$CONNECT_REPORT" >&2
    exit 1
fi
/usr/bin/python3 -c '
import json
import sys

records = [json.loads(line) for line in open(sys.argv[1], encoding="utf-8") if line.strip()]
ready = [
    record for record in records
    if record.get("event") == "hook_status" and record.get("runtimeStatus") == "ready"
]
if not ready:
    raise SystemExit("Approved Codex hooks did not refresh to ready without an event")
pending = [
    record for record in records
    if record.get("event") == "hook_status"
    and record.get("runtimeStatus") == "review_required"
]
if len(pending) < 3:
    raise SystemExit("Approval was not delayed beyond the old finite polling window")
if not any(record.get("staleHookResultsDiscarded", 0) >= 1 for record in records):
    raise SystemExit("Startup status/install race did not discard the stale status result")
if any(
    record.get("event") == "hook_status" and record.get("hookState") == "notInstalled"
    for record in records
):
    raise SystemExit("A stale pre-install status overwrote the completed installation")
if ready[-1].get("connectionStatus") != "waitingForActivity":
    raise SystemExit("Ready hooks were not presented as waiting for activity")
if ready[-1].get("connectionStatusConsistent") is not True:
    raise SystemExit("Ready hook status diverged between popover and menu")
if ready[-1].get("connectionGuidanceVisible") is not True:
    raise SystemExit("Ready hooks did not show the first-activity instruction")
if ready[-1].get("connectionActionVisible") is not False:
    raise SystemExit("Ready hooks still exposed the Codex review action")
' "$CONNECT_REPORT"
stop_e2e_app_pid "$STATUS_PID"
STATUS_PID=

check_unavailable_review_recovery() {
    case_name=$1
    report_path=$2
    log_path=$3
    launch_failure=$4
    expected_action=$5
    case_home="$E2E_ROOT/$case_name-home"
    mkdir -p "$case_home"
    env \
        HOME="$case_home" \
        AGENT_MEONG_E2E_AUTO_CONNECT=1 \
        AGENT_MEONG_E2E_AUTO_CONNECT_DURING_STATUS=1 \
        AGENT_MEONG_E2E_CODEX_BIN=/usr/bin/false \
        AGENT_MEONG_E2E_REVIEW_LAUNCH_FAIL="$launch_failure" \
        AGENT_MEONG_E2E_SUPPRESS_OPEN=1 \
        AGENT_MEONG_E2E_REPORT="$report_path" \
        AGENT_MEONG_SOCKET="$E2E_ROOT/$case_name.sock" \
        "$APP/Contents/MacOS/AgentMeong" >"$log_path" 2>&1 &
    STATUS_PID=$!
    wait_for_event_in "$report_path" "$log_path" hook_installation
    /usr/bin/python3 -c '
import json
import sys

record = next(
    value
    for value in (json.loads(line) for line in open(sys.argv[1], encoding="utf-8"))
    if value.get("event") == "hook_installation"
)
expected_launch = sys.argv[2] == "0"
if record.get("runtimeStatus") != "unavailable":
    raise SystemExit(f"Unavailable Codex fixture reported the wrong runtime state: {record}")
if record.get("reviewLaunchSucceeded") is not expected_launch:
    raise SystemExit(f"Codex review launch result was not preserved: {record}")
if record.get("connectionAction") != sys.argv[3]:
    raise SystemExit(f"Unavailable Codex recovery exposed the wrong action: {record}")
if record.get("reviewRecoveryGuidanceVisible") is not True:
    raise SystemExit(f"Unavailable Codex recovery hid its next-step guidance: {record}")
' "$report_path" "$launch_failure" "$expected_action"
    stop_e2e_app_pid "$STATUS_PID"
    STATUS_PID=
}

check_unavailable_review_recovery \
    unavailable-opened "$UNAVAILABLE_OPENED_REPORT" "$UNAVAILABLE_OPENED_LOG" \
    0 refreshStatus
check_unavailable_review_recovery \
    unavailable-failed "$UNAVAILABLE_FAILED_REPORT" "$UNAVAILABLE_FAILED_LOG" \
    1 review

