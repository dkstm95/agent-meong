#!/bin/sh

set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
CODEX_COMMAND=${CODEX_BIN:-codex}
CODEX_PATH=$(command -v "$CODEX_COMMAND" 2>/dev/null || true)

if [ -z "$CODEX_PATH" ] || [ ! -x "$CODEX_PATH" ]; then
    echo "agent-meong Codex CLI acceptance requires an installed codex command" >&2
    exit 1
fi

exec /usr/bin/python3 - "$ROOT" "$CODEX_PATH" <<'PY'
from __future__ import annotations

import base64
import json
import os
import pathlib
import re
import socket
import subprocess
import sys
import tempfile
import threading
import time
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from typing import Any, Dict, List, Optional


MODEL_NAME = "gpt-oss:20b"
SYNTHETIC_PROMPT = "raw-prompt-must-not-cross-boundary"
ALLOWED_OBSERVATION_KEYS = {
    "schemaVersion",
    "eventId",
    "source",
    "sessionId",
    "actorId",
    "parentActorId",
    "scopeId",
    "occurredAt",
    "kind",
    "integrationVersion",
    "integrationInstance",
    "toolCategory",
}
OPAQUE_ID_PATTERN = re.compile(r"^[0-9a-f]{32}$")
INSTANCE_PATTERN = re.compile(r"^(?:unscoped|[0-9a-f]{24,64})$")


class AcceptanceFailure(Exception):
    pass


HOOK_TABLE_PATTERN = re.compile(
    r"(?im)^\s*(?:\[\[?\s*hooks(?:[.\]]|\s)|hooks\s*=\s*\{)"
)


def toml_defines_hooks(contents: str) -> bool:
    return HOOK_TABLE_PATTERN.search(contents) is not None


def file_defines_hooks(path: pathlib.Path) -> bool:
    try:
        contents = path.read_text(encoding="utf-8")
    except FileNotFoundError:
        return False
    except (OSError, UnicodeError) as error:
        raise AcceptanceFailure(f"cannot inspect external hook source: {path}") from error
    if path.suffix == ".json":
        try:
            document = json.loads(contents)
        except json.JSONDecodeError as error:
            raise AcceptanceFailure(f"cannot inspect external hook source: {path}") from error
        return isinstance(document, dict) and bool(document.get("hooks"))
    return toml_defines_hooks(contents)


def ensure_no_detected_external_hooks():
    candidates = (
        pathlib.Path("/etc/codex/hooks.json"),
        pathlib.Path("/etc/codex/config.toml"),
        pathlib.Path("/etc/codex/requirements.toml"),
        pathlib.Path("/etc/codex/managed_config.toml"),
    )
    for path in candidates:
        ensure(not file_defines_hooks(path), f"external hook source detected: {path}")

    defaults = pathlib.Path("/usr/bin/defaults")
    if not defaults.is_file():
        return
    managed = subprocess.run(
        [str(defaults), "read", "com.openai.codex", "requirements_toml_base64"],
        stdin=subprocess.DEVNULL,
        capture_output=True,
        text=True,
        timeout=3,
        check=False,
    )
    if managed.returncode != 0:
        return
    encoded = managed.stdout.strip().strip('"')
    try:
        decoded = base64.b64decode(encoded, validate=True).decode("utf-8")
    except (ValueError, UnicodeError) as error:
        raise AcceptanceFailure("cannot inspect macOS managed Codex requirements") from error
    ensure(
        not toml_defines_hooks(decoded),
        "macOS managed hook source detected",
    )


class QuietHTTPServer(ThreadingHTTPServer):
    daemon_threads = True

    def __init__(self, server_address, handler_class):
        super().__init__(server_address, handler_class)
        self.model_request_count = 0
        self.had_internal_error = False
        self.spawn_tool_seen = False
        self.first_tool_names: List[str] = []
        self.request_lock = threading.Lock()

    def handle_error(self, request, client_address):
        self.had_internal_error = True


class LocalModelHandler(BaseHTTPRequestHandler):
    def log_message(self, format, *args):
        return

    def do_GET(self):
        if self.path not in {"/api/tags", "/v1/models"}:
            self.send_error(404)
            return
        body = json.dumps({
            "models": [{"name": MODEL_NAME, "id": MODEL_NAME}],
        }).encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_POST(self):
        content_length = int(self.headers.get("Content-Length", "0"))
        request_bytes = self.rfile.read(content_length)
        if not self.path.endswith("/responses"):
            self.send_error(404)
            return

        try:
            request = json.loads(request_bytes)
        except (UnicodeDecodeError, json.JSONDecodeError):
            self.send_error(400)
            return
        with self.server.request_lock:
            self.server.model_request_count += 1
            request_number = self.server.model_request_count

        spawn_tool_name = None
        spawn_namespace = None
        for tool in request.get("tools", []):
            if not isinstance(tool, dict):
                continue
            tool_name = tool.get("name")
            if isinstance(tool_name, str) and tool_name.endswith("spawn_agent"):
                spawn_tool_name = tool_name
                break
            if tool.get("type") != "namespace" or not isinstance(tool_name, str):
                continue
            nested_spawn = next(
                (
                    nested.get("name")
                    for nested in tool.get("tools", [])
                    if isinstance(nested, dict)
                    and nested.get("name") == "spawn_agent"
                ),
                None,
            )
            if nested_spawn is not None:
                spawn_tool_name = nested_spawn
                spawn_namespace = tool_name
                break
        if request_number == 1:
            self.server.first_tool_names = [
                str(tool.get("name") or tool.get("type") or "unknown")
                for tool in request.get("tools", [])
                if isinstance(tool, dict)
            ]
        if request_number == 1 and spawn_tool_name is not None:
            self.server.spawn_tool_seen = True
            output_item = {
                "id": "fc_agent_meong_spawn",
                "type": "function_call",
                "status": "completed",
                "name": spawn_tool_name,
                "call_id": "call_agent_meong_spawn",
                "arguments": json.dumps({
                    "message": "Return a short answer without using tools.",
                }),
            }
            if spawn_namespace is not None:
                output_item["namespace"] = spawn_namespace
        else:
            output_item = {
                "id": f"msg_agent_meong_acceptance_{request_number}",
                "type": "message",
                "status": "completed",
                "role": "assistant",
                "content": [{
                    "type": "output_text",
                    "annotations": [],
                    "logprobs": [],
                    "text": "ok",
                }],
            }
        usage = {
            "input_tokens": 1,
            "input_tokens_details": {"cached_tokens": 0},
            "output_tokens": 1,
            "output_tokens_details": {"reasoning_tokens": 0},
            "total_tokens": 2,
        }
        response = {
            "id": f"resp_agent_meong_acceptance_{request_number}",
            "object": "response",
            "created_at": 1,
            "status": "completed",
            "background": False,
            "error": None,
            "incomplete_details": None,
            "instructions": None,
            "max_output_tokens": None,
            "max_tool_calls": None,
            "model": MODEL_NAME,
            "output": [output_item],
            "parallel_tool_calls": True,
            "previous_response_id": None,
            "prompt_cache_key": None,
            "reasoning": {"effort": None, "summary": None},
            "safety_identifier": None,
            "service_tier": "default",
            "store": False,
            "temperature": 1.0,
            "text": {"format": {"type": "text"}, "verbosity": "medium"},
            "tool_choice": "auto",
            "tools": [],
            "top_logprobs": 0,
            "top_p": 1.0,
            "truncation": "disabled",
            "usage": usage,
            "user": None,
            "metadata": {},
        }
        events = [
            {
                "type": "response.output_item.done",
                "sequence_number": 1,
                "output_index": 0,
                "item": output_item,
            },
            {
                "type": "response.completed",
                "sequence_number": 2,
                "response": response,
            },
        ]
        body = b"".join(
            b"event: " + event["type"].encode("utf-8") + b"\n"
            + b"data: " + json.dumps(event).encode("utf-8") + b"\n\n"
            for event in events
        )
        self.send_response(200)
        self.send_header("Content-Type", "text/event-stream")
        self.send_header("Cache-Control", "no-cache")
        self.send_header("Connection", "close")
        self.end_headers()
        self.wfile.write(body)


class ObservationCapture:
    def __init__(self, path: pathlib.Path):
        self.path = path
        self.events: List[Dict[str, Any]] = []
        self.failure: Optional[str] = None
        self.ready = threading.Event()
        self.complete = threading.Event()
        self.stopping = threading.Event()
        self.server = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        self.server.bind(str(path))
        os.chmod(path, 0o600)
        self.server.listen(8)
        self.server.settimeout(0.1)
        self.thread = threading.Thread(target=self._run, daemon=True)

    def start(self):
        self.thread.start()
        self.ready.wait(timeout=1)

    def _run(self):
        self.ready.set()
        while not self.stopping.is_set() and len(self.events) < 64:
            try:
                connection, _ = self.server.accept()
            except socket.timeout:
                continue
            except OSError:
                break
            with connection:
                data = b""
                while len(data) < 65_536 and b"\n" not in data:
                    chunk = connection.recv(4_096)
                    if not chunk:
                        break
                    data += chunk
            try:
                for line in data.splitlines():
                    event = json.loads(line)
                    if not isinstance(event, dict):
                        self.failure = "adapter socket emitted a non-object observation"
                        break
                    self.events.append(event)
            except (UnicodeDecodeError, json.JSONDecodeError):
                self.failure = "adapter socket emitted invalid JSON"
                break
        self.complete.set()

    def wait_until_quiet(self, timeout: float):
        deadline = time.monotonic() + timeout
        previous_count = -1
        stable_polls = 0
        while time.monotonic() < deadline:
            current_count = len(self.events)
            if current_count == previous_count and current_count >= 5:
                stable_polls += 1
                if stable_polls >= 5:
                    return
            else:
                stable_polls = 0
            previous_count = current_count
            time.sleep(0.1)

    def close(self):
        self.stopping.set()
        self.thread.join(timeout=1)
        self.server.close()


def ensure(condition: bool, message: str):
    if not condition:
        raise AcceptanceFailure(message)


def isolated_environment(home: pathlib.Path, codex_home: pathlib.Path, socket_path: pathlib.Path):
    environment = {
        "PATH": os.environ.get("PATH", "/usr/bin:/bin"),
        "LANG": os.environ.get("LANG", "en_US.UTF-8"),
        "HOME": str(home),
        "CODEX_HOME": str(codex_home),
        "AGENT_MEONG_SOCKET": str(socket_path),
        "NO_PROXY": "127.0.0.1,localhost",
        "no_proxy": "127.0.0.1,localhost",
        "HTTP_PROXY": "http://127.0.0.1:9",
        "HTTPS_PROXY": "http://127.0.0.1:9",
        "ALL_PROXY": "http://127.0.0.1:9",
        "http_proxy": "http://127.0.0.1:9",
        "https_proxy": "http://127.0.0.1:9",
        "all_proxy": "http://127.0.0.1:9",
        "OTEL_SDK_DISABLED": "true",
    }
    return environment


def validate_observations(events: List[Dict[str, Any]]):
    ensure(
        len(events) >= 5,
        "expected main and subagent lifecycle observations; observed "
        + ", ".join(str(event.get("kind")) for event in events),
    )
    for event in events:
        ensure(set(event).issubset(ALLOWED_OBSERVATION_KEYS), "observation crossed privacy boundary")
        ensure(event.get("schemaVersion") == 0, "unexpected observation schema")
        ensure(event.get("source") == "openai.codex", "unexpected observation source")
        ensure(
            event.get("integrationVersion") == "dev.ailab.agent-meong/v4",
            "unexpected adapter integration version",
        )
        ensure(
            INSTANCE_PATTERN.fullmatch(str(event.get("integrationInstance") or ""))
            is not None,
            "invalid opaque integration instance",
        )
        for key in ("eventId", "sessionId", "actorId", "scopeId"):
            ensure(
                OPAQUE_ID_PATTERN.fullmatch(str(event.get(key) or "")) is not None,
                f"invalid opaque {key}",
            )
        if "parentActorId" in event:
            ensure(
                OPAQUE_ID_PATTERN.fullmatch(str(event["parentActorId"])) is not None,
                "invalid opaque parentActorId",
            )
    ensure(
        len({event["eventId"] for event in events}) == len(events),
        "lifecycle events were not distinct",
    )
    main_started = next(
        (event for event in events if event.get("kind") == "turn.started"
         and "parentActorId" not in event),
        None,
    )
    main_stopped = next(
        (event for event in events if event.get("kind") == "turn.stopping"
         and "parentActorId" not in event),
        None,
    )
    child_started = next(
        (event for event in events if event.get("kind") == "agent.started"),
        None,
    )
    child_stopped = next(
        (event for event in events if event.get("kind") == "agent.finished"),
        None,
    )
    child_activity = next(
        (event for event in events if event.get("kind") in {
            "turn.started", "tool.started", "tool.finished", "approval.waiting"
        } and "parentActorId" in event),
        None,
    )
    ensure(main_started is not None and main_stopped is not None, "root turn lifecycle missing")
    ensure(child_started is not None and child_stopped is not None, "subagent lifecycle missing")
    ensure(child_activity is not None, "subagent activity was not attributed to the child")
    ensure(main_started["actorId"] == main_stopped["actorId"], "root actor identity changed")
    ensure(main_started["scopeId"] == main_stopped["scopeId"], "root turn identity changed")
    ensure(child_started["actorId"] == child_stopped["actorId"], "child actor identity changed")
    ensure(child_activity["actorId"] == child_started["actorId"], "child activity split actors")
    ensure(
        child_started["parentActorId"] == main_started["actorId"]
        and child_activity["parentActorId"] == main_started["actorId"],
        "subagent parent identity did not point to the root actor",
    )
    ensure(
        SYNTHETIC_PROMPT not in json.dumps(events, sort_keys=True),
        "prompt text crossed the observation boundary",
    )


def main(root: pathlib.Path, codex_path: pathlib.Path):
    ensure_no_detected_external_hooks()
    with tempfile.TemporaryDirectory(prefix="agent-meong-codex-", dir="/tmp") as directory:
        temporary = pathlib.Path(directory)
        home = temporary / "home"
        codex_home = temporary / "codex-home"
        work = temporary / "work"
        socket_path = temporary / "events.sock"
        home.mkdir()
        codex_home.mkdir()
        work.mkdir()

        capture = ObservationCapture(socket_path)
        model_server = QuietHTTPServer(("127.0.0.1", 0), LocalModelHandler)
        model_thread = threading.Thread(target=model_server.serve_forever, daemon=True)
        capture.start()
        model_thread.start()
        environment = isolated_environment(home, codex_home, socket_path)
        environment["CODEX_OSS_BASE_URL"] = (
            f"http://127.0.0.1:{model_server.server_port}/v1"
        )

        try:
            install = subprocess.run(
                ["/bin/bash", str(root / "scripts/install-codex-hook")],
                env=environment,
                stdin=subprocess.DEVNULL,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                timeout=10,
                check=False,
            )
            ensure(install.returncode == 0, "isolated hook installation failed")

            command = [
                str(codex_path),
                "exec",
                "--ephemeral",
                "--ignore-user-config",
                "--enable",
                "hooks",
                "--disable",
                "plugins",
                "--dangerously-bypass-hook-trust",
                "--sandbox",
                "read-only",
                "-c",
                'approval_policy="never"',
                "--oss",
                "--local-provider",
                "ollama",
                "-m",
                MODEL_NAME,
                "--skip-git-repo-check",
                "-C",
                str(work),
                SYNTHETIC_PROMPT,
            ]
            try:
                completed = subprocess.run(
                    command,
                    env=environment,
                    stdin=subprocess.DEVNULL,
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                    timeout=20,
                    check=False,
                )
            except subprocess.TimeoutExpired as error:
                raise AcceptanceFailure("Codex CLI timed out") from error

            ensure(completed.returncode == 0, "Codex CLI process failed")
            capture.wait_until_quiet(timeout=5)
            ensure(capture.failure is None, capture.failure or "socket capture failed")
            ensure(
                model_server.spawn_tool_seen,
                "Codex did not expose spawn_agent; tools: "
                + ", ".join(model_server.first_tool_names),
            )
            validate_observations(capture.events)
            ensure(model_server.model_request_count >= 2, "subagent did not reach the local model")
            ensure(not model_server.had_internal_error, "local model server failed")
        finally:
            capture.close()
            model_server.shutdown()
            model_server.server_close()
            model_thread.join(timeout=1)


try:
    main(pathlib.Path(sys.argv[1]), pathlib.Path(sys.argv[2]))
except AcceptanceFailure as error:
    print(f"agent-meong Codex CLI acceptance failed: {error}", file=sys.stderr)
    raise SystemExit(1)
except (OSError, subprocess.SubprocessError):
    print("agent-meong Codex CLI acceptance failed: local harness error", file=sys.stderr)
    raise SystemExit(1)

print(
    "agent-meong Codex CLI acceptance: "
    "root and subagent lifecycle reached the adapter socket"
)
PY
