#!/bin/sh

set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
TMP_BASE=${TMPDIR:-/tmp}
E2E_ROOT=$(mktemp -d "$TMP_BASE/agent-meong-e2e.XXXXXX")
E2E_ROOT=$(CDPATH= cd -- "$E2E_ROOT" && pwd -P)
E2E_HOME="$E2E_ROOT/home"
INSTALLED_ADAPTER_ROOT="$E2E_HOME/Library/Application Support/AgentMeong/codex-hooks"
SOCKET="$E2E_ROOT/events.sock"
REPORT="$E2E_ROOT/report.jsonl"
LOG="$E2E_ROOT/app.log"
SECOND_REPORT="$E2E_ROOT/second-report.jsonl"
SECOND_LOG="$E2E_ROOT/second-app.log"
RELAUNCH_REPORT="$E2E_ROOT/relaunch-report.jsonl"
RELAUNCH_LOG="$E2E_ROOT/relaunch-app.log"
RACE_SOCKET="$E2E_ROOT/startup-race.sock"
RACE_A_REPORT="$E2E_ROOT/race-a-report.jsonl"
RACE_A_LOG="$E2E_ROOT/race-a.log"
RACE_B_REPORT="$E2E_ROOT/race-b-report.jsonl"
RACE_B_LOG="$E2E_ROOT/race-b.log"
DISABLED_REPORT="$E2E_ROOT/disabled-report.jsonl"
DISABLED_LOG="$E2E_ROOT/disabled.log"
MANAGED_REPORT="$E2E_ROOT/managed-report.jsonl"
MANAGED_LOG="$E2E_ROOT/managed.log"
INLINE_REPORT="$E2E_ROOT/inline-report.jsonl"
INLINE_LOG="$E2E_ROOT/inline.log"
TRUST_STATE_REPORT="$E2E_ROOT/trust-state-report.jsonl"
TRUST_STATE_LOG="$E2E_ROOT/trust-state.log"
CUSTOM_REPORT="$E2E_ROOT/custom-report.jsonl"
CUSTOM_LOG="$E2E_ROOT/custom.log"
CUSTOM_RELAUNCH_REPORT="$E2E_ROOT/custom-relaunch-report.jsonl"
CUSTOM_RELAUNCH_LOG="$E2E_ROOT/custom-relaunch.log"
CUSTOM_CLEARED_REPORT="$E2E_ROOT/custom-cleared-report.jsonl"
CUSTOM_CLEARED_LOG="$E2E_ROOT/custom-cleared.log"
CONFIRMATION_SUITE="dev.ailab.agent-meong.e2e.$$"
LEGEND_SUITE="dev.ailab.agent-meong.legend.e2e.$$"
CONNECT_HOME="$E2E_ROOT/connect-home"
CONNECT_REPORT="$E2E_ROOT/connect-report.jsonl"
CONNECT_LOG="$E2E_ROOT/connect.log"
KOREAN_REPORT="$E2E_ROOT/korean-report.jsonl"
KOREAN_LOG="$E2E_ROOT/korean.log"
ENGLISH_REPORT="$E2E_ROOT/english-report.jsonl"
ENGLISH_LOG="$E2E_ROOT/english.log"
REMOVAL_REPORT="$E2E_ROOT/removal-report.jsonl"
REMOVAL_LOG="$E2E_ROOT/removal.log"
PACKAGED_APP="$ROOT/dist/AgentMeong.app"
APP="$E2E_ROOT/AgentMeong.app"
APP_EXECUTABLE="$APP/Contents/MacOS/AgentMeong"
APP_PID=
APP_LAUNCHER_PID=
SECOND_APP_PID=
RELAUNCH_APP_PID=
RACE_A_PID=
RACE_B_PID=
STATUS_PID=
SEND_SEQUENCE=0

is_e2e_app_pid() {
    pid=$1
    case "$pid" in
        ''|*[!0-9]*) return 1 ;;
    esac
    command=$(/bin/ps -p "$pid" -o command= 2>/dev/null || true)
    case "$command" in
        "$APP_EXECUTABLE"|"$APP_EXECUTABLE "*) return 0 ;;
    esac
    return 1
}

stop_e2e_app_pid() {
    pid=$1
    if is_e2e_app_pid "$pid"; then
        /bin/kill -TERM "$pid" 2>/dev/null || true
    fi
    wait "$pid" 2>/dev/null || true
}

e2e_app_pids() {
    /usr/bin/pgrep -x AgentMeong 2>/dev/null | while IFS= read -r pid; do
        if is_e2e_app_pid "$pid"; then
            printf '%s\n' "$pid"
        fi
    done
}

cleanup() {
    if [ -n "$APP_PID" ]; then
        stop_e2e_app_pid "$APP_PID"
    fi
    if [ -n "$SECOND_APP_PID" ]; then
        stop_e2e_app_pid "$SECOND_APP_PID"
    fi
    if [ -n "$RELAUNCH_APP_PID" ]; then
        stop_e2e_app_pid "$RELAUNCH_APP_PID"
    fi
    if [ -n "$RACE_A_PID" ]; then
        stop_e2e_app_pid "$RACE_A_PID"
    fi
    if [ -n "$RACE_B_PID" ]; then
        stop_e2e_app_pid "$RACE_B_PID"
    fi
    if [ -n "$STATUS_PID" ]; then
        stop_e2e_app_pid "$STATUS_PID"
    fi
    for pid in $(e2e_app_pids); do
        stop_e2e_app_pid "$pid"
    done
    if [ -n "$APP_LAUNCHER_PID" ]; then
        launcher_command=$(/bin/ps -p "$APP_LAUNCHER_PID" -o command= 2>/dev/null || true)
        case "$launcher_command" in
            "/usr/bin/open -n -W "*"$APP")
                /bin/kill -TERM "$APP_LAUNCHER_PID" 2>/dev/null || true
                ;;
        esac
        wait "$APP_LAUNCHER_PID" 2>/dev/null || true
    fi
    /usr/bin/defaults delete "$CONFIRMATION_SUITE" 2>/dev/null || true
    /usr/bin/defaults delete "$LEGEND_SUITE" 2>/dev/null || true
    rm -rf "$E2E_ROOT"
}
trap cleanup EXIT INT TERM

wait_for_event() {
    wait_for_event_in "$REPORT" "$LOG" "$1"
}

wait_for_event_count() {
    report_path=$1
    log_path=$2
    event=$3
    expected_count=$4
    attempts=0
    while [ "$attempts" -lt 100 ]; do
        count=0
        if [ -f "$report_path" ]; then
            count=$(grep -c -F "\"event\":\"$event\"" "$report_path" || true)
        fi
        if [ "$count" -ge "$expected_count" ]; then
            return 0
        fi
        attempts=$((attempts + 1))
        sleep 0.1
    done
    echo "Timed out waiting for $event count $expected_count" >&2
    if [ -f "$report_path" ]; then
        tail -n 60 "$report_path" >&2
    fi
    if [ -f "$log_path" ]; then
        sed -n '1,120p' "$log_path" >&2
    fi
    return 1
}

wait_for_event_in() {
    report_path=$1
    log_path=$2
    event=$3
    attempts=0
    while [ "$attempts" -lt 100 ]; do
        if [ -f "$report_path" ] && grep -F "\"event\":\"$event\"" "$report_path" >/dev/null; then
            return 0
        fi
        attempts=$((attempts + 1))
        sleep 0.1
    done
    echo "Timed out waiting for $event" >&2
    if [ -f "$report_path" ]; then
        tail -n 60 "$report_path" >&2
    fi
    if [ -f "$log_path" ]; then
        sed -n '1,120p' "$log_path" >&2
    fi
    return 1
}

send_until_observed() {
    payload=$1
    send_observation "$SOCKET" "$INSTALLED_ADAPTER" "$payload"
    attempts=0
    while [ "$attempts" -lt 20 ]; do
        if [ -f "$REPORT" ] && grep -F '"event":"observation"' "$REPORT" >/dev/null; then
            return 0
        fi
        attempts=$((attempts + 1))
        sleep 0.1
    done
    echo "Timed out sending the first observation" >&2
    if [ -f "$REPORT" ]; then
        tail -n 50 "$REPORT" >&2
    fi
    if [ -f "$LOG" ]; then
        sed -n '1,120p' "$LOG" >&2
    fi
    return 1
}

send_observation() {
    socket_path=$1
    adapter_path=$2
    payload=$3
    SEND_SEQUENCE=$((SEND_SEQUENCE + 1))
    attempts=0
    while [ "$attempts" -lt 20 ]; do
        if printf '%s\n' "$payload" | env \
            AGENT_MEONG_E2E_DELIVERY_DIAGNOSTICS=1 \
            AGENT_MEONG_E2E_REQUIRE_DELIVERY=1 \
            AGENT_MEONG_SOCKET="$socket_path" \
            /usr/bin/python3 "$adapter_path"
        then
            return 0
        fi
        attempts=$((attempts + 1))
        sleep 0.05
    done
    SOCKET_PRESENT=false
    PRIMARY_ALIVE=false
    [ -S "$socket_path" ] && SOCKET_PRESENT=true
    if [ -n "$APP_PID" ] && is_e2e_app_pid "$APP_PID"; then
        PRIMARY_ALIVE=true
    fi
    echo "Timed out delivering observation $SEND_SEQUENCE to $socket_path" >&2
    echo "socketPresent=$SOCKET_PRESENT primaryAlive=$PRIMARY_ALIVE" >&2
    return 1
}

bash "$ROOT/scripts/package-app" >/dev/null
/usr/bin/ditto "$PACKAGED_APP" "$APP"
/usr/bin/defaults delete "$CONFIRMATION_SUITE" 2>/dev/null || true
/usr/bin/defaults delete "$LEGEND_SUITE" 2>/dev/null || true
mkdir -p "$CONNECT_HOME"
env \
    HOME="$CONNECT_HOME" \
    AGENT_MEONG_E2E_AUTO_CONNECT=1 \
    AGENT_MEONG_E2E_SUPPRESS_OPEN=1 \
    AGENT_MEONG_E2E_REPORT="$CONNECT_REPORT" \
    AGENT_MEONG_SOCKET="$E2E_ROOT/connect.sock" \
    "$APP/Contents/MacOS/AgentMeong" >"$CONNECT_LOG" 2>&1 &
STATUS_PID=$!
wait_for_event_in "$CONNECT_REPORT" "$CONNECT_LOG" hook_installation
test -f "$CONNECT_HOME/.codex/hooks.json"
test "$(find "$CONNECT_HOME/Library/Application Support/AgentMeong/codex-hooks" \
    -type f -name codex_hook.py | wc -l | tr -d ' ')" = "1"
/usr/bin/python3 -c '
import json
import sys

records = [json.loads(line) for line in open(sys.argv[1], encoding="utf-8") if line.strip()]
installation = next(record for record in records if record.get("event") == "hook_installation")
if installation.get("hookInstalled") is not True:
    raise SystemExit("Onboarding action did not install the user hook")
if installation.get("hooksCommandCopied") is not True:
    raise SystemExit("Installed onboarding did not copy /hooks")
' "$CONNECT_REPORT"
stop_e2e_app_pid "$STATUS_PID"
STATUS_PID=

mkdir -p "$E2E_HOME"
HOME="$E2E_HOME" /usr/bin/python3 \
    "$APP/Contents/Resources/codex_hook.py" --install | grep -F '"status": "installed"' >/dev/null
test -f "$E2E_HOME/.codex/hooks.json"
test "$(find "$INSTALLED_ADAPTER_ROOT" -type f -name codex_hook.py | wc -l | tr -d ' ')" = "1"
INSTALLED_ADAPTER=$(find "$INSTALLED_ADAPTER_ROOT" -type f -name codex_hook.py)
test -f "$INSTALLED_ADAPTER"

/usr/bin/open -n -W \
    --env "HOME=$E2E_HOME" \
    --env "AGENT_MEONG_E2E_AUTO_OPEN_COMPLETION_RECEIPTS=1" \
    --env "AGENT_MEONG_E2E_AUTO_REOPEN_STATE_LEGEND=1" \
    --env "AGENT_MEONG_E2E_DEFAULTS_SUITE=$LEGEND_SUITE" \
    --env "AGENT_MEONG_E2E_REPORT=$REPORT" \
    --env "AGENT_MEONG_SOCKET=$SOCKET" \
    --env "AGENT_MEONG_E2E_STATE_LEGEND_DURATION=10" \
    "$APP" >"$LOG" 2>&1 &
APP_LAUNCHER_PID=$!

wait_for_event launched
APP_PID=$(/usr/bin/python3 - "$REPORT" <<'PY'
import json
import sys

records = [json.loads(line) for line in open(sys.argv[1], encoding="utf-8") if line.strip()]
print(next(record["processID"] for record in records if record.get("event") == "launched"))
PY
)
if ! is_e2e_app_pid "$APP_PID"; then
    echo "LaunchServices reported an unexpected AgentMeong process: $APP_PID" >&2
    exit 1
fi
wait_for_event hook_status
wait_for_event popover_opened
wait_for_event popover_active
wait_for_event popover_geometry

/usr/bin/python3 - "$SOCKET" <<'PY'
import json
import socket
import sys
import time

messages = [
    {
        "schemaVersion": 999,
        "eventId": "00000000000000000000000000000001",
        "source": "openai.codex",
        "sessionId": "10000000000000000000000000000001",
        "actorId": "20000000000000000000000000000001",
        "occurredAt": "2026-07-15T00:00:00Z",
        "kind": "turn.started",
    },
    {
        "schemaVersion": 0,
        "eventId": "00000000000000000000000000000002",
        "source": "openai.codex",
        "sessionId": "10000000000000000000000000000002",
        "actorId": "20000000000000000000000000000002",
        "occurredAt": "2026-07-15T00:00:00Z",
        "kind": "turn.started",
        "prompt": "must never cross the observation boundary",
    },
    {
        "schemaVersion": 0,
        "eventId": "00000000000000000000000000000003",
        "source": "openai.codex",
        "sessionId": "raw prompt or /private/file must be rejected",
        "actorId": "20000000000000000000000000000003",
        "occurredAt": "2026-07-15T00:00:00Z",
        "kind": "turn.started",
    },
    {
        "schemaVersion": 0,
        "eventId": "00000000000000000000000000000004",
        "source": "codex",
        "sessionId": "10000000000000000000000000000004",
        "actorId": "20000000000000000000000000000004",
        "occurredAt": "2026-07-15T00:00:00Z",
        "kind": "turn.started",
    },
    {
        "schemaVersion": 0,
        "eventId": "00000000000000000000000000000005",
        "source": "openai.codex",
        "sessionId": "10000000000000000000000000000005",
        "actorId": "20000000000000000000000000000005",
        "occurredAt": "2026-07-15T00:00:00Z",
        "kind": "turn.started",
        "integrationVersion": "/private/secret",
        "integrationInstance": "unscoped",
    },
    {
        "schemaVersion": 0,
        "eventId": "00000000000000000000000000000006",
        "source": "openai.codex",
        "sessionId": "10000000000000000000000000000006",
        "actorId": "20000000000000000000000000000006",
        "occurredAt": "2026-07-15T00:00:00Z",
        "kind": "turn.started",
        "integrationVersion": "dev.ailab.agent-meong/v4",
        "integrationInstance": "/Users/private",
    },
    {
        "schemaVersion": 0,
        "eventId": "00000000000000000000000000000007",
        "source": "openai.codex",
        "sessionId": "10000000000000000000000000000007",
        "actorId": "20000000000000000000000000000007",
        "scopeId": None,
        "occurredAt": "2026-07-15T00:00:00Z",
        "kind": "turn.started",
    },
]
for message in messages:
    payload = (json.dumps(message) + "\n").encode("utf-8")
    for attempt in range(20):
        client = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        try:
            client.connect(sys.argv[1])
            client.sendall(payload)
            break
        except (BrokenPipeError, ConnectionRefusedError):
            if attempt == 19:
                raise
            time.sleep(0.02)
        finally:
            client.close()
PY
attempts=0
while [ "$attempts" -lt 100 ]; do
    if grep -F '"rejectedEventCount":7' "$REPORT" >/dev/null 2>&1; then
        break
    fi
    attempts=$((attempts + 1))
    sleep 0.1
done
if [ "$attempts" -eq 100 ]; then
    echo "Timed out waiting for all privacy-unsafe observations to be rejected" >&2
    exit 1
fi
if grep -F '"event":"observation"' "$REPORT" >/dev/null; then
    echo "Invalid or privacy-unsafe observation mutated the app state" >&2
    exit 1
fi
if grep -F '"event":"state_legend_' "$REPORT" >/dev/null; then
    echo "Rejected observations incorrectly triggered the state legend" >&2
    exit 1
fi

send_until_observed '{"hook_event_name":"UserPromptSubmit","session_id":"e2e-session-a","turn_id":"e2e-turn-a"}'
wait_for_event_count "$REPORT" "$LOG" state_legend_shown 1

# Close immediately after the first presentation so this assertion measures
# popover-driven cancellation rather than host load versus a wall-clock timer.
/usr/bin/osascript -e 'tell application "Finder" to activate'
wait_for_event_count "$REPORT" "$LOG" popover_closed 1
sleep 0.1
if grep -F '"event":"state_legend_completed"' "$REPORT" >/dev/null; then
    echo "State legend completed after its popover started closing" >&2
    exit 1
fi
wait_for_event_count "$REPORT" "$LOG" state_legend_shown 2

send_observation "$SOCKET" "$INSTALLED_ADAPTER" \
    '{"hook_event_name":"PreToolUse","session_id":"e2e-session-a","turn_id":"e2e-turn-a","tool_use_id":"e2e-tool-a","tool_name":"Bash"}'
send_observation "$SOCKET" "$INSTALLED_ADAPTER" \
    '{"hook_event_name":"PostToolUse","session_id":"e2e-session-a","turn_id":"e2e-turn-a","tool_use_id":"e2e-tool-a","tool_name":"Bash"}'
send_observation "$SOCKET" "$INSTALLED_ADAPTER" \
    '{"hook_event_name":"UserPromptSubmit","session_id":"e2e-session-b","turn_id":"e2e-turn-b"}'
wait_for_event_count "$REPORT" "$LOG" observation 4
send_observation "$SOCKET" "$INSTALLED_ADAPTER" \
    '{"hook_event_name":"PermissionRequest","session_id":"e2e-session-a","turn_id":"e2e-turn-a","tool_name":"Bash"}'
wait_for_event_count "$REPORT" "$LOG" observation 5
send_observation "$SOCKET" "$INSTALLED_ADAPTER" \
    '{"hook_event_name":"PermissionRequest","session_id":"e2e-session-b","turn_id":"e2e-turn-b","tool_name":"Bash"}'
wait_for_event_count "$REPORT" "$LOG" observation 6
send_observation "$SOCKET" "$INSTALLED_ADAPTER" \
    '{"hook_event_name":"UserPromptSubmit","session_id":"e2e-session-a","turn_id":"e2e-turn-a-resumed"}'
wait_for_event_count "$REPORT" "$LOG" observation 7
send_observation "$SOCKET" "$INSTALLED_ADAPTER" \
    '{"hook_event_name":"UserPromptSubmit","session_id":"e2e-session-b","turn_id":"e2e-turn-b-resumed"}'
wait_for_event_count "$REPORT" "$LOG" observation 8
send_observation "$SOCKET" "$INSTALLED_ADAPTER" \
    '{"hook_event_name":"SubagentStart","session_id":"e2e-session-b","turn_id":"e2e-turn-b","agent_id":"e2e-child"}'
wait_for_event_count "$REPORT" "$LOG" observation 9
send_observation "$SOCKET" "$INSTALLED_ADAPTER" \
    '{"hook_event_name":"SubagentStop","session_id":"e2e-session-b","turn_id":"e2e-turn-b","agent_id":"e2e-child"}'
wait_for_event_count "$REPORT" "$LOG" observation 10
send_observation "$SOCKET" "$INSTALLED_ADAPTER" \
    '{"hook_event_name":"Stop","session_id":"e2e-session-a","turn_id":"e2e-turn-a-resumed"}'
wait_for_event_count "$REPORT" "$LOG" observation 11
send_observation "$SOCKET" "$INSTALLED_ADAPTER" \
    '{"hook_event_name":"Stop","session_id":"e2e-session-b","turn_id":"e2e-turn-b-resumed"}'
wait_for_event_count "$REPORT" "$LOG" observation 12
wait_for_event state_legend_completed
/usr/bin/osascript -e 'tell application "Finder" to activate'
wait_for_event_count "$REPORT" "$LOG" popover_closed 2

send_observation "$SOCKET" "$INSTALLED_ADAPTER" \
    '{"hook_event_name":"UserPromptSubmit","session_id":"e2e-session-c","turn_id":"e2e-turn-c"}'
wait_for_event_count "$REPORT" "$LOG" observation 13
send_observation "$SOCKET" "$INSTALLED_ADAPTER" \
    '{"hook_event_name":"Stop","session_id":"e2e-session-c","turn_id":"e2e-turn-c"}'
wait_for_event_count "$REPORT" "$LOG" observation 14

/usr/bin/python3 -c '
import json
import sys
import time

path = sys.argv[1]
deadline = time.time() + 10
records = []
while time.time() < deadline:
    with open(path, encoding="utf-8") as handle:
        records = [json.loads(line) for line in handle if line.strip()]
    observations = [record for record in records if record.get("event") == "observation"]
    finished_while_hidden = any(
        record.get("workEndUnseen") is True
        and record.get("aggregateState") == "finished"
        and record.get("liveActorCount") == 0
        for record in observations
    )
    receipts_presented = any(
        record.get("event") == "completion_receipts_presented"
        and record.get("completionReceiptCount") == 1
        and record.get("completionReceiptsAccessible") is True
        for record in records
    )
    if len(observations) >= 10 and finished_while_hidden and receipts_presented:
        break
    time.sleep(0.1)
else:
    summary = [
        (
            record.get("aggregateState"),
            record.get("liveActorCount"),
            record.get("childBirths"),
            record.get("childAbsorptions"),
        )
        for record in observations
    ]
    raise SystemExit(
        f"Timed out waiting for finished observation: "
        f"count={len(observations)}, states={summary}"
    )

allowed = {
    "accessibilityMenuAction",
    "activeActorCount",
    "anchorAligned",
    "aggregateState",
    "attentionAccessibilityNotified",
    "attentionActorCount",
    "attentionCountAccessible",
    "childAbsorptions",
    "childBirths",
    "completionReceiptCount",
    "completionReceiptsAcknowledged",
    "completionReceiptsAccessible",
    "workEndNotified",
    "workEndUnseen",
    "connectionGuidanceVisible",
    "event",
    "fitsVisibleScreen",
    "hookInstalled",
    "hookState",
    "horizontallyAligned",
    "inlineHooksPresent",
    "liveActorCount",
    "managedHookPresent",
    "onboardingNeeded",
    "popoverBehavior",
    "popoverBehaviorRestored",
    "processID",
    "receiverReady",
    "rejectedEventCount",
    "sameScreen",
    "stateLegendAccessible",
    "stateLegendVersion",
    "stateLegendVisible",
    "toolFinishes",
    "toolStarts",
    "unseenWorkEndCount",
    "verticallyAttached",
}
if any(set(record) - allowed for record in records):
    raise SystemExit("E2E report contains fields outside the privacy allowlist")
if not any(record.get("event") == "launched" and record.get("receiverReady") for record in records):
    raise SystemExit("Packaged app receiver did not start")
if not any(
    record.get("event") == "launched"
    and record.get("accessibilityMenuAction") is True
    for record in records
):
    raise SystemExit("Status item does not expose its context menu as an accessibility action")
if not any(record.get("event") == "hook_status" and record.get("hookInstalled") for record in records):
    raise SystemExit("Packaged app did not detect the isolated user hook installation")
if not any(
    record.get("event") == "hook_status"
    and record.get("onboardingNeeded") is True
    and record.get("connectionGuidanceVisible") is True
    for record in records
):
    raise SystemExit("First unconfirmed connection did not show onboarding guidance")
if not any(record.get("event") == "launched" and record.get("popoverBehavior") == "transient" for record in records):
    raise SystemExit("Packaged app popover is not transient")
popover_geometry = next(
    (record for record in records if record.get("event") == "popover_geometry"),
    None,
)
if (
    popover_geometry is None
    or popover_geometry.get("anchorAligned") is not True
    or popover_geometry.get("fitsVisibleScreen") is not True
    or popover_geometry.get("sameScreen") is not True
):
    raise SystemExit(
        f"Popover was not attached to the status item inside its visible screen: {popover_geometry}"
    )
if not any(record.get("event") == "popover_closed" for record in records):
    raise SystemExit("Popover close delegate did not run")
legend_shown = [record for record in records if record.get("event") == "state_legend_shown"]
legend_completed = [
    record for record in records if record.get("event") == "state_legend_completed"
]
if len(legend_shown) != 2 or len(legend_completed) != 1:
    raise SystemExit(
        f"State legend did not retry once and complete only after redisplay: "
        f"shown={legend_shown}, completed={legend_completed}"
    )
if any(
    record.get("stateLegendVisible") is not True
    or record.get("stateLegendAccessible") is not True
    or record.get("stateLegendVersion") != 1
    for record in legend_shown
):
    raise SystemExit(f"State legend was not visible and accessible on each display: {legend_shown}")
if legend_completed[0].get("stateLegendVisible") is not False:
    raise SystemExit(f"Completed state legend remained visible: {legend_completed[0]}")
if legend_completed[0].get("popoverBehaviorRestored") is not True:
    raise SystemExit(f"State legend retry did not restore transient behavior: {legend_completed[0]}")
if observations[0].get("aggregateState") != "active" or observations[0].get("liveActorCount") != 1:
    raise SystemExit("Start hook did not create one active logical actor")
attention_updates = [
    record
    for record in observations
    if record.get("attentionActorCount") in {1, 2}
    and record.get("aggregateState") == "attention"
]
if [record.get("attentionActorCount") for record in attention_updates[:2]] != [1, 2]:
    raise SystemExit(f"Attention actor counts were not tracked independently: {attention_updates}")
if any(
    record.get("attentionAccessibilityNotified") is not True
    or record.get("attentionCountAccessible") is not True
    for record in attention_updates[:2]
):
    raise SystemExit(
        f"Attention increases were not announced with an accurate accessible count: "
        f"{attention_updates[:2]}"
    )
if not any(record.get("toolStarts") == 1 for record in observations):
    raise SystemExit("Tool start did not create one transient visual impulse")
if not any(record.get("toolFinishes") == 1 for record in observations):
    raise SystemExit("Tool finish did not create one transient visual impulse")
if not any(record.get("childBirths") == 1 for record in observations):
    raise SystemExit("Subagent start did not schedule one child birth")
if not any(record.get("childAbsorptions") == 1 for record in observations):
    raise SystemExit("Subagent stop did not schedule one child absorption")
if not any(
    record.get("workEndNotified") is True
    and record.get("workEndUnseen") is False
    and record.get("aggregateState") == "active"
    and record.get("activeActorCount") == 1
    for record in observations
):
    raise SystemExit("Partial top-level work end did not notify while other work stayed active")
child_end = next(
    (record for record in observations if record.get("childAbsorptions") == 1),
    None,
)
if child_end is None or child_end.get("workEndNotified") is not False:
    raise SystemExit("Subagent end incorrectly triggered the top-level work-end signal")
if not any(record.get("workEndUnseen") is True for record in observations):
    raise SystemExit("Work end while the popover was closed did not remain visible")
receipt = next(
    (record for record in records if record.get("event") == "completion_receipts_presented"),
    None,
)
if (
    receipt is None
    or receipt.get("completionReceiptCount") != 1
    or receipt.get("completionReceiptsAcknowledged") is not True
    or receipt.get("completionReceiptsAccessible") is not True
):
    raise SystemExit(f"Agent-specific completion receipt was not presented accessibly: {receipt}")
if observations[-1].get("aggregateState") != "finished" or observations[-1].get("liveActorCount") != 0:
    raise SystemExit("Stop hook did not finish the logical actor")
' "$REPORT"

env \
    HOME="$E2E_HOME" \
    AGENT_MEONG_E2E_SUPPRESS_OPEN=1 \
    AGENT_MEONG_E2E_REPORT="$SECOND_REPORT" \
    AGENT_MEONG_SOCKET="$SOCKET" \
    "$APP/Contents/MacOS/AgentMeong" >"$SECOND_LOG" 2>&1 &
SECOND_APP_PID=$!
wait_for_event_in "$SECOND_REPORT" "$SECOND_LOG" launched
