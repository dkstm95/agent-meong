    AGENT_MEONG_INSTALL_DIR="$MIGRATION_INSTALL_ROOT" \
    AGENT_MEONG_TEST_LAUNCH_AGENTS_DIR="$MIGRATION_LAUNCH_AGENTS_DIR" \
    AGENT_MEONG_TEST_LAUNCHCTL_STATE_FILE="$MIGRATION_LAUNCHCTL_STATE" \
