        raise SystemExit(f"Manual state legend did not preserve the seen state: {record}")
    if record.get("stateLegendHelpIcon") is not True:
        raise SystemExit(f"State legend help control was not an accessible icon: {record}")
' "$RELAUNCH_REPORT"

