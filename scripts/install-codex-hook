#!/bin/sh

set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
result=$(/usr/bin/python3 "$ROOT/adapters/codex_hook.py" --install)
printf '%s\n' "$result" | grep -F '"status": "installed"' >/dev/null
echo "Codex 사용자 연결을 설치했습니다."
echo "Codex App 또는 CLI에서 새 task를 시작해 hook 정의를 검토하세요."
echo "CLI에서는 /hooks로 lifecycle event와 command를 신뢰할 수 있습니다."
