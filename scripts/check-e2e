send_observation "$E2E_ROOT/removal.sock" "$REMOVAL_CUSTOM_ADAPTER" \
    '{"hook_event_name":"UserPromptSubmit","session_id":"custom-finished-session","turn_id":"custom-finished-turn"}'
wait_for_event_count "$REMOVAL_REPORT" "$REMOVAL_LOG" observation 1
send_observation "$E2E_ROOT/removal.sock" "$REMOVAL_CUSTOM_ADAPTER" \
    '{"hook_event_name":"Stop","session_id":"custom-finished-session","turn_id":"custom-finished-turn"}'
wait_for_event_count "$REMOVAL_REPORT" "$REMOVAL_LOG" observation 2
send_observation "$E2E_ROOT/removal.sock" "$REMOVAL_CUSTOM_ADAPTER" \
    '{"hook_event_name":"UserPromptSubmit","session_id":"custom-active-session","turn_id":"custom-active-turn"}'
wait_for_event_count "$REMOVAL_REPORT" "$REMOVAL_LOG" observation 3
send_observation "$E2E_ROOT/removal.sock" "$REMOVAL_DEFAULT_ADAPTER" \
    '{"hook_event_name":"UserPromptSubmit","session_id":"default-session","turn_id":"default-turn"}'
wait_for_event_count "$REMOVAL_REPORT" "$REMOVAL_LOG" observation 4
send_observation_without_owner "$E2E_ROOT/removal.sock" "$REMOVAL_DEFAULT_ADAPTER" \
    '{"hook_event_name":"Stop","session_id":"default-session","turn_id":"default-turn"}'
wait_for_event_in "$REMOVAL_REPORT" "$REMOVAL_LOG" hook_removal
/usr/bin/python3 - "$REMOVAL_REPORT" <<'PY'
import json
import sys

records = [json.loads(line) for line in open(sys.argv[1], encoding="utf-8") if line.strip()]
status = next(record for record in records if record.get("event") == "hook_status")
observations = [record for record in records if record.get("event") == "observation"]
removal = next(record for record in records if record.get("event") == "hook_removal")
if status.get("hookState") != "installed" or status.get("managedHookPresent") is not True:
    raise SystemExit(f"Removal fixture did not begin with a managed default hook: {status}")
if len(observations) != 5 or not any(
    record.get("liveActorCount") == 2 for record in observations
):
    raise SystemExit(f"Mixed default/custom observations did not create two actors: {observations}")
if removal.get("hookState") != "notInstalled" or removal.get("managedHookPresent") is not False:
    raise SystemExit(f"Current default hook was not removed: {removal}")
if (
    removal.get("confirmationCleared") is not False
    or removal.get("liveActorCount") != 1
    or removal.get("completionReceiptCount") != 1
    or removal.get("connectionActionVisible") is not True
):
    raise SystemExit(f"Removing the default hook cleared custom history or the scene: {removal}")
PY
HOME="$REMOVAL_HOME" CODEX_HOME="$REMOVAL_DEFAULT_HOME" /usr/bin/python3 \
    "$APP/Contents/Resources/codex_hook.py" --status \
    | grep -F '"status": "not_installed"' >/dev/null
HOME="$REMOVAL_HOME" CODEX_HOME="$REMOVAL_CUSTOM_HOME" /usr/bin/python3 \
    "$APP/Contents/Resources/codex_hook.py" --status \
    | grep -F '"status": "installed"' >/dev/null
stop_e2e_app_pid "$STATUS_PID"
STATUS_PID=

