import json
import sys

records = [json.loads(line) for line in open(sys.argv[1], encoding="utf-8") if line.strip()]
events = [record.get("event") for record in records]
first_open = events.index("popover_opened")
closing = events.index("popover_closing", first_open + 1)
ended = next(
    index for index, record in enumerate(records)
    if index > closing and record.get("event") == "observation"
    and record.get("workEndUnseen") is True
)
closed = events.index("popover_closed", ended + 1)
second_open = events.index("popover_opened", closed + 1)
receipt_index = events.index("completion_receipts_presented", second_open + 1)
if not first_open < closing < ended < closed < second_open < receipt_index:
    raise SystemExit(f"Closing receipt events were out of order: {events}")
receipts = [record for record in records if record.get("event") == "completion_receipts_presented"]
if len(receipts) != 1 or receipts[0].get("completionReceiptCount") != 1:
    raise SystemExit(f"Closing Stop was not acknowledged exactly once after redisplay: {receipts}")
if receipts[0].get("completionReceiptsAcknowledged") is not True:
    raise SystemExit(f"Closing Stop receipt was not acknowledged after didShow: {receipts[0]}")
PY
