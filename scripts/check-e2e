    AGENT_MEONG_E2E_REPORT="$REMOVAL_REVERSE_REPORT" \
    AGENT_MEONG_SOCKET="$E2E_ROOT/removal-reverse.sock" \
    "$APP/Contents/MacOS/AgentMeong" >"$REMOVAL_REVERSE_LOG" 2>&1 &
STATUS_PID=$!
wait_for_event_in "$REMOVAL_REVERSE_REPORT" "$REMOVAL_REVERSE_LOG" hook_status
send_observation "$E2E_ROOT/removal-reverse.sock" "$REMOVAL_REVERSE_DEFAULT_ADAPTER" \
    '{"hook_event_name":"UserPromptSubmit","session_id":"reverse-shared-session","turn_id":"reverse-shared-turn"}'
wait_for_event_count "$REMOVAL_REVERSE_REPORT" "$REMOVAL_REVERSE_LOG" observation 1
send_observation "$E2E_ROOT/removal-reverse.sock" "$REMOVAL_REVERSE_CUSTOM_ADAPTER" \
    '{"hook_event_name":"UserPromptSubmit","session_id":"reverse-shared-session","turn_id":"reverse-shared-turn"}'
wait_for_event_count "$REMOVAL_REVERSE_REPORT" "$REMOVAL_REVERSE_LOG" observation 2
wait_for_event_in "$REMOVAL_REVERSE_REPORT" "$REMOVAL_REVERSE_LOG" hook_removal
/usr/bin/python3 - "$REMOVAL_REVERSE_REPORT" <<'PY'
import json
import sys

records = [json.loads(line) for line in open(sys.argv[1], encoding="utf-8") if line.strip()]
observations = [record for record in records if record.get("event") == "observation"]
mixed = observations[-1]
if (
    mixed.get("currentHookConfirmed") is not True
    or mixed.get("separateConnectionConfirmed") is not True
    or mixed.get("separateForgetVisible") is not True
    or mixed.get("onboardingNeeded") is not False
    or mixed.get("connectionGuidanceVisible") is not False
    or mixed.get("connectionStatus") != "connectedRecent"
    or mixed.get("connectionStatusConsistent") is not True
    or mixed.get("liveActorCount") != 2
):
    raise SystemExit(
        f"Default/custom state collided for identical raw Codex IDs: {mixed}"
    )
removal = next(record for record in records if record.get("event") == "hook_removal")
if (
    removal.get("defaultActorsRemaining") is not False
    or removal.get("customActorPreserved") is not True
    or removal.get("customConfirmationPreserved") is not True
    or removal.get("connectionStatus") != "connectedRecent"
    or removal.get("connectionActionVisible") is not True
):
    raise SystemExit(f"Reverse-order default removal lost the custom connection: {removal}")
PY
HOME="$REMOVAL_REVERSE_HOME" CODEX_HOME="$REMOVAL_REVERSE_DEFAULT_HOME" /usr/bin/python3 \
    "$APP/Contents/Resources/codex_hook.py" --status \
    | grep -F '"status": "not_installed"' >/dev/null
HOME="$REMOVAL_REVERSE_HOME" CODEX_HOME="$REMOVAL_REVERSE_CUSTOM_HOME" /usr/bin/python3 \
    "$APP/Contents/Resources/codex_hook.py" --status \
    | grep -F '"status": "installed"' >/dev/null
stop_e2e_app_pid "$STATUS_PID"
STATUS_PID=

/usr/bin/python3 -c '
import json
import sys

allowed_events = {
    "completion_receipts_accessibility_retained",
    "completion_receipts_presented",
    "connection_forget",
    "hook_installation",
    "hook_removal",
    "hook_status",
    "launched",
    "localization",
    "observation",
    "observation_rejected",
    "popover_active",
    "popover_closed",
    "popover_closing",
    "popover_geometry",
    "popover_opened",
    "state_legend_completed",
    "state_legend_shown",
}
allowed_fields = {
    "accessibilityMenuAction",
    "activeActorCount",
    "anchorAligned",
    "aggregateState",
    "attentionAccessibilityNotified",
    "attentionActorCount",
    "attentionCountAccessible",
    "childAbsorptions",
    "childBirths",
    "completionReceiptAccessibilityCleared",
    "completionReceiptCount",
    "completionReceiptsAcknowledged",
    "completionReceiptsAccessible",
    "workEndNotified",
    "workEndUnseen",
    "connectionActionVisible",
    "connectionAction",
    "connectionGuidanceVisible",
    "connectionGuidanceLayoutValid",
    "connectionGuidanceScrollable",
    "connectionStatus",
    "connectionStatusConsistent",
    "confirmationCleared",
    "currentHookConfirmed",
    "customActorPreserved",
    "customConfirmationPreserved",
    "defaultActorsRemaining",
    "event",
    "fitsVisibleScreen",
    "hookInstalled",
    "hooksCommandCopied",
    "hookState",
    "horizontallyAligned",
    "inlineHooksPresent",
    "inlineAdvisory",
    "language",
    "liveActorCount",
    "localizedSample",
    "minuteRefreshSeconds",
    "managedHookPresent",
    "onboardingNeeded",
    "popoverBehavior",
    "popoverBehaviorRestored",
    "processID",
    "receiverReady",
    "reviewLaunchSucceeded",
    "reviewRecoveryGuidanceVisible",
    "reduceMotionEnabled",
    "runtimeStatus",
    "sceneStaticActiveCue",
    "separateConnectionConfirmed",
    "separateForgetVisible",
    "recentRefreshSeconds",
    "rejectedEventCount",
    "sameScreen",
    "stateLegendAccessible",
    "stateLegendHelpIcon",
    "stateLegendManual",
    "stateLegendPreviouslySeen",
    "stateLegendReduceMotionStatic",
    "stateLegendVersion",
    "stateLegendVisible",
    "staleHookResultsDiscarded",
    "statusItemStaticActiveCue",
    "toolFinishes",
    "toolStarts",
    "unseenWorkEndCount",
    "hourRefreshSeconds",
    "verticallyAttached",
}
for path in sys.argv[1:]:
    records = [json.loads(line) for line in open(path, encoding="utf-8") if line.strip()]
    if any(record.get("event") not in allowed_events for record in records):
        raise SystemExit(f"E2E report emitted an event outside the privacy allowlist: {path}")
    if any(set(record) - allowed_fields for record in records):
        raise SystemExit(f"E2E report emitted fields outside the privacy allowlist: {path}")
' "$REPORT" "$SECOND_REPORT" "$RELAUNCH_REPORT" "$RACE_A_REPORT" "$RACE_B_REPORT" \
    "$DISABLED_REPORT" "$MANAGED_REPORT" "$INLINE_REPORT" "$LONG_GUIDANCE_REPORT" \
    "$TRUST_STATE_REPORT" \
    "$CUSTOM_REPORT" \
    "$CUSTOM_RELAUNCH_REPORT" "$CUSTOM_CLEARED_REPORT" "$CONNECT_REPORT" \
    "$UNAVAILABLE_OPENED_REPORT" "$UNAVAILABLE_FAILED_REPORT" \
    "$KOREAN_REPORT" "$ENGLISH_REPORT" "$REDUCE_MOTION_REPORT" \
    "$CLOSING_REPORT" "$REPAIR_REPORT" "$FORGET_MIXED_REPORT" "$REMOVAL_REPORT" \
    "$REMOVAL_REVERSE_REPORT"

echo "agent-meong E2E: hook, socket, localized UI, lifecycle, and privacy passed"
