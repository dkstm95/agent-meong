HOME="$REMOVAL_HOME" CODEX_HOME="$REMOVAL_DEFAULT_HOME" /usr/bin/python3 \
    "$APP/Contents/Resources/codex_hook.py" --install \
    | grep -F '"status": "installed"' >/dev/null
HOME="$REMOVAL_HOME" CODEX_HOME="$REMOVAL_CUSTOM_HOME" /usr/bin/python3 \
    "$APP/Contents/Resources/codex_hook.py" --install \
    | grep -F '"status": "installed"' >/dev/null
REMOVAL_CUSTOM_ADAPTER=$(/usr/bin/python3 - "$REMOVAL_CUSTOM_HOME/hooks.json" <<'PY'
import json
import shlex
import sys

with open(sys.argv[1], encoding="utf-8") as handle:
    document = json.load(handle)
command = document["hooks"]["UserPromptSubmit"][0]["hooks"][0]["command"]
print(shlex.split(command)[0])
PY
)
REMOVAL_DEFAULT_ADAPTER=$(/usr/bin/python3 - "$REMOVAL_DEFAULT_HOME/hooks.json" <<'PY'
import json
import shlex
import sys

with open(sys.argv[1], encoding="utf-8") as handle:
    document = json.load(handle)
command = document["hooks"]["UserPromptSubmit"][0]["hooks"][0]["command"]
print(shlex.split(command)[0])
PY
)
test -f "$REMOVAL_CUSTOM_ADAPTER"
test -f "$REMOVAL_DEFAULT_ADAPTER"
env \
    HOME="$REMOVAL_HOME" \
    AGENT_MEONG_E2E_AUTO_REMOVE_HOOK=1 \
    AGENT_MEONG_E2E_EXPIRE_ACTORS_BEFORE_REMOVAL=1 \
    AGENT_MEONG_E2E_REMOVE_AFTER_PRESENTED_RECEIPTS=1 \
    AGENT_MEONG_E2E_SUPPRESS_OPEN=1 \
    AGENT_MEONG_E2E_REPORT="$REMOVAL_REPORT" \
    AGENT_MEONG_SOCKET="$E2E_ROOT/removal.sock" \
    "$APP/Contents/MacOS/AgentMeong" >"$REMOVAL_LOG" 2>&1 &
STATUS_PID=$!
