    "$ISOLATED_LAUNCH_AGENTS_DIR/$LOGIN_ITEM_LABEL.plist" \
    "$ISOLATED_INSTALL_ROOT/AgentMeong.app"
test "$(/bin/cat "$ISOLATED_LAUNCHCTL_STATE")" = "loaded"
test "$(launchctl_mutation_count "$ISOLATED_LAUNCHCTL_LOG")" = "1"

