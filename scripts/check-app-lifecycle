    AGENT_MEONG_TEST_PACKAGE_APP="$FAILED_REPLACEMENT_APP" \
    AGENT_MEONG_TEST_FAIL_AFTER_LOGIN_ITEM=1 \
    /bin/bash "$ROOT/scripts/install-app" >/dev/null 2>"$CHECK_ROOT/migration-rollback.stderr"
then
    echo "legacy login item migration rollback unexpectedly succeeded" >&2
    exit 1
fi
assert_legacy_login_item "$MIGRATION_LOGIN_ITEM" "$MIGRATION_APP"
test "$(login_item_fingerprint "$MIGRATION_LOGIN_ITEM")" = "$MIGRATION_FINGERPRINT"
