env \
    HOME="$CUSTOM_HOME" \
    AGENT_MEONG_E2E_DEFAULTS_SUITE="$CONFIRMATION_SUITE" \
    AGENT_MEONG_E2E_SUPPRESS_OPEN=1 \
    AGENT_MEONG_E2E_REPORT="$CUSTOM_CLEARED_REPORT" \
    AGENT_MEONG_SOCKET="$E2E_ROOT/custom-cleared.sock" \
    "$APP/Contents/MacOS/AgentMeong" >"$CUSTOM_CLEARED_LOG" 2>&1 &
STATUS_PID=$!
wait_for_event_in "$CUSTOM_CLEARED_REPORT" "$CUSTOM_CLEARED_LOG" hook_status
/usr/bin/python3 -c '
import json
import sys

records = [json.loads(line) for line in open(sys.argv[1], encoding="utf-8") if line.strip()]
status = next(record for record in records if record.get("event") == "hook_status")
if status.get("onboardingNeeded") is not True:
    raise SystemExit("Cleared custom confirmation returned after relaunch")
if status.get("connectionGuidanceVisible") is not True:
    raise SystemExit("Cleared custom confirmation did not keep guidance visible")
' "$CUSTOM_CLEARED_REPORT"
stop_e2e_app_pid "$STATUS_PID"
STATUS_PID=

for LANGUAGE_CASE in ko en; do
    if [ "$LANGUAGE_CASE" = ko ]; then
        LANGUAGE_HOME="$E2E_ROOT/korean-home"
        LANGUAGE_REPORT="$KOREAN_REPORT"
        LANGUAGE_LOG="$KOREAN_LOG"
    else
        LANGUAGE_HOME="$E2E_ROOT/english-home"
        LANGUAGE_REPORT="$ENGLISH_REPORT"
        LANGUAGE_LOG="$ENGLISH_LOG"
    fi
    mkdir -p "$LANGUAGE_HOME"
    env \
        HOME="$LANGUAGE_HOME" \
        AGENT_MEONG_LANGUAGE="$LANGUAGE_CASE" \
        AGENT_MEONG_E2E_REPORT_LOCALIZATION=1 \
        AGENT_MEONG_E2E_SUPPRESS_OPEN=1 \
        AGENT_MEONG_E2E_REPORT="$LANGUAGE_REPORT" \
        AGENT_MEONG_SOCKET="$E2E_ROOT/$LANGUAGE_CASE.sock" \
        "$APP/Contents/MacOS/AgentMeong" >"$LANGUAGE_LOG" 2>&1 &
    STATUS_PID=$!
    wait_for_event_in "$LANGUAGE_REPORT" "$LANGUAGE_LOG" localization
    wait_for_event_in "$LANGUAGE_REPORT" "$LANGUAGE_LOG" hook_status
    /usr/bin/python3 - "$LANGUAGE_REPORT" "$LANGUAGE_CASE" <<'PY'
import json
import sys

records = [json.loads(line) for line in open(sys.argv[1], encoding="utf-8") if line.strip()]
localization = next(record for record in records if record.get("event") == "localization")
status = next(record for record in records if record.get("event") == "hook_status")
expected_sample = "Codex 연결" if sys.argv[2] == "ko" else "Connect Codex"
if localization != {
    "event": "localization",
    "hourRefreshSeconds": 3500,
    "language": sys.argv[2],
    "localizedSample": expected_sample,
    "minuteRefreshSeconds": 45,
    "recentRefreshSeconds": 5,
}:
    raise SystemExit(f"Language override did not select the expected UI copy: {localization}")
if status.get("hookState") != "notInstalled" or status.get("connectionActionVisible") is not True:
    raise SystemExit(f"First-run onboarding did not expose Connect: {status}")
PY
    stop_e2e_app_pid "$STATUS_PID"
    STATUS_PID=
done

REMOVAL_HOME="$E2E_ROOT/removal-home"
REMOVAL_DEFAULT_HOME="$REMOVAL_HOME/.codex"
REMOVAL_CUSTOM_HOME="$E2E_ROOT/removal-custom-codex"
