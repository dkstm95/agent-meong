#!/bin/sh

set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
if result=$(/usr/bin/python3 "$ROOT/adapters/codex_hook.py" --uninstall); then
    :
else
    status=$?
    exit "$status"
fi
if ! printf '%s\n' "$result" | grep -F '"status": "not_installed"' >/dev/null; then
    printf 'Could not completely remove the Codex connection / Codex мӮ¬мҡ©мһҗ м—°кІ°мқ„ мҷ„м „нһҲ н•ҙм ңн•ҳм§Җ лӘ»н–ҲмҠөлӢҲлӢӨ: %s\n' "$result" >&2
    exit 1
fi
echo "Removed the agent-meong Codex user connection. / agent-meongмқҳ Codex мӮ¬мҡ©мһҗ м—°кІ°мқ„ н•ҙм ңн–ҲмҠөлӢҲлӢӨ."
