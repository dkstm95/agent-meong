#!/bin/sh

set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
if result=$(/usr/bin/python3 "$ROOT/adapters/codex_hook.py" --uninstall); then
    :
else
    status=$?
    exit "$status"
fi
if ! printf '%s\n' "$result" | grep -F '"status": "not_installed"' >/dev/null; then
    printf 'Could not completely remove the Codex connection / Codex 사용자 연결을 완전히 해제하지 못했습니다: %s\n' "$result" >&2
    exit 1
fi
echo "Removed the agent-meong Codex user connection. / agent-meong의 Codex 사용자 연결을 해제했습니다."
echo "Fully quit and reopen running Codex App and CLI instances so they drop the removed hook."
echo "실행 중인 Codex App과 CLI를 완전히 종료하고 다시 열어 제거된 hook을 반영하세요."
echo "Review /hooks again: removing a positional hook can require trust review for other user hooks whose positions changed."
echo "/hooks를 다시 확인하세요. 위치 기반 hook 제거로 뒤의 다른 사용자 hook도 재검토가 필요할 수 있습니다."
