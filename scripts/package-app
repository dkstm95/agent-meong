#!/bin/sh

set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
MACOS_ROOT="$ROOT/macos"
CACHE="$MACOS_ROOT/.build/local-cache"
APP="$ROOT/dist/AgentMeong.app"
CONFIGURATION=${CONFIGURATION:-debug}
CODESIGN_IDENTITY=${CODESIGN_IDENTITY:--}

case "$CONFIGURATION" in
    debug|release) ;;
    *) echo "CONFIGURATION must be debug or release" >&2; exit 2 ;;
esac

mkdir -p "$CACHE/clang" "$CACHE/swiftpm" "$CACHE/config" "$CACHE/security"

cd "$MACOS_ROOT"
export CLANG_MODULE_CACHE_PATH="$CACHE/clang"
export SWIFTPM_MODULECACHE_OVERRIDE="$CACHE/swiftpm"

swift build --disable-sandbox \
    --configuration "$CONFIGURATION" \
    --cache-path "$CACHE/swiftpm" \
    --config-path "$CACHE/config" \
    --security-path "$CACHE/security" \
    --product AgentMeong
swift build --disable-sandbox \
    --configuration "$CONFIGURATION" \
    --cache-path "$CACHE/swiftpm" \
    --config-path "$CACHE/config" \
    --security-path "$CACHE/security" \
    --product AgentMeongCodexForwarder
BIN_PATH=$(swift build --disable-sandbox \
    --configuration "$CONFIGURATION" \
    --cache-path "$CACHE/swiftpm" \
    --config-path "$CACHE/config" \
    --security-path "$CACHE/security" \
    --show-bin-path)

rm -rf "$APP"
mkdir -p "$APP/Contents/MacOS" "$APP/Contents/Resources" "$APP/Contents/Helpers"
cp "$BIN_PATH/AgentMeong" "$APP/Contents/MacOS/AgentMeong"
cp "$BIN_PATH/AgentMeongCodexForwarder" \
    "$APP/Contents/Helpers/codex_hook_forwarder"
cp "$MACOS_ROOT/Resources/Info.plist" "$APP/Contents/Info.plist"
cp "$MACOS_ROOT/Resources/AgentMeong.icns" \
    "$APP/Contents/Resources/AgentMeong.icns"
cp "$ROOT/adapters/codex_hook.py" "$APP/Contents/Resources/codex_hook.py"
cp "$MACOS_ROOT/Resources/open-codex-hook-review.command" \
    "$APP/Contents/Resources/open-codex-hook-review.command"
chmod 755 "$APP/Contents/MacOS/AgentMeong"
chmod 755 "$APP/Contents/Helpers/codex_hook_forwarder"
chmod 644 "$APP/Contents/Resources/AgentMeong.icns"
chmod 644 "$APP/Contents/Resources/codex_hook.py"
chmod 755 "$APP/Contents/Resources/open-codex-hook-review.command"
if [ "$CODESIGN_IDENTITY" = "-" ]; then
    codesign --force --sign - "$APP/Contents/Helpers/codex_hook_forwarder"
    codesign --force --sign - "$APP"
else
    codesign --force --options runtime --timestamp --sign "$CODESIGN_IDENTITY" \
        "$APP/Contents/Helpers/codex_hook_forwarder"
    codesign --force --options runtime --timestamp --sign "$CODESIGN_IDENTITY" "$APP"
fi

echo "$APP"
