#!/bin/sh

set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
CODEX_COMMAND=${CODEX_BIN:-codex}
CODEX_PATH=$(command -v "$CODEX_COMMAND" 2>/dev/null || true)

if [ -z "$CODEX_PATH" ] || [ ! -x "$CODEX_PATH" ]; then
    echo "agent-meong Codex CLI acceptance requires an installed codex command" >&2
    exit 1
fi

exec /usr/bin/python3 - "$ROOT" "$CODEX_PATH" <<'PY'
from __future__ import annotations

import base64
import importlib.util
import json
import os
import pathlib
import re
import socket
import subprocess
import sys
import tempfile
import threading
import time
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from typing import Any, Dict, List, Optional


MODEL_NAME = "gpt-oss:20b"
SYNTHETIC_PROMPT = "raw-prompt-must-not-cross-boundary"
ALLOWED_OBSERVATION_KEYS = {
    "schemaVersion",
    "eventId",
    "source",
    "sessionId",
    "actorId",
    "parentActorId",
    "scopeId",
    "occurredAt",
    "kind",
    "integrationVersion",
    "integrationInstance",
    "toolCategory",
}
OPAQUE_ID_PATTERN = re.compile(r"^[0-9a-f]{32}$")
INSTANCE_PATTERN = re.compile(r"^(?:unscoped|[0-9a-f]{24,64})$")


class AcceptanceFailure(Exception):
    pass


HOOK_TABLE_PATTERN = re.compile(
    r"(?im)^\s*(?:\[\[?\s*hooks(?:[.\]]|\s)|hooks\s*=\s*\{)"
)


def toml_defines_hooks(contents: str) -> bool:
    return HOOK_TABLE_PATTERN.search(contents) is not None


def file_defines_hooks(path: pathlib.Path) -> bool:
    try:
        contents = path.read_text(encoding="utf-8")
    except FileNotFoundError:
        return False
    except (OSError, UnicodeError) as error:
        raise AcceptanceFailure(f"cannot inspect external hook source: {path}") from error
    if path.suffix == ".json":
        try:
            document = json.loads(contents)
        except json.JSONDecodeError as error:
            raise AcceptanceFailure(f"cannot inspect external hook source: {path}") from error
        return isinstance(document, dict) and bool(document.get("hooks"))
    return toml_defines_hooks(contents)


def ensure_no_detected_external_hooks():
    candidates = (
        pathlib.Path("/etc/codex/hooks.json"),
        pathlib.Path("/etc/codex/config.toml"),
        pathlib.Path("/etc/codex/requirements.toml"),
        pathlib.Path("/etc/codex/managed_config.toml"),
    )
    for path in candidates:
        ensure(not file_defines_hooks(path), f"external hook source detected: {path}")

    defaults = pathlib.Path("/usr/bin/defaults")
    if not defaults.is_file():
        return
    managed = subprocess.run(
        [str(defaults), "read", "com.openai.codex", "requirements_toml_base64"],
        stdin=subprocess.DEVNULL,
        capture_output=True,
        text=True,
        timeout=3,
        check=False,
    )
    if managed.returncode != 0:
        return
    encoded = managed.stdout.strip().strip('"')
    try:
        decoded = base64.b64decode(encoded, validate=True).decode("utf-8")
    except (ValueError, UnicodeError) as error:
        raise AcceptanceFailure("cannot inspect macOS managed Codex requirements") from error
    ensure(
        not toml_defines_hooks(decoded),
        "macOS managed hook source detected",
    )


def spawned_agent_target(request: Dict[str, Any]) -> Optional[str]:
    """Read only the isolated fixture's spawn result to drive wait_agent."""

    def find_target(value: Any) -> Optional[str]:
        if isinstance(value, dict):
            for key in ("agent_id", "agentId", "id"):
                candidate = value.get(key)
                if isinstance(candidate, str) and candidate:
                    return candidate
            for nested in value.values():
                candidate = find_target(nested)
                if candidate is not None:
                    return candidate
            return None
        if isinstance(value, list):
            for nested in value:
                candidate = find_target(nested)
                if candidate is not None:
                    return candidate
            return None
        if not isinstance(value, str):
            return None
        try:
            parsed = json.loads(value)
        except json.JSONDecodeError:
            parsed = None
        if parsed is not None and parsed != value:
            candidate = find_target(parsed)
            if candidate is not None:
                return candidate
        match = re.search(
            r"(?i)agent[_ -]?id[\"' :=]+([A-Za-z0-9_.:-]+)",
            value,
        )
        return match.group(1) if match is not None else None

    for item in request.get("input", []):
        if not isinstance(item, dict):
            continue
        if item.get("call_id") != "call_agent_meong_spawn":
            continue
        return find_target(item.get("output"))
    return None


def contains_call_id(value: Any, call_id: str) -> bool:
    if isinstance(value, dict):
        if value.get("call_id") == call_id:
            return True
        return any(contains_call_id(nested, call_id) for nested in value.values())
    if isinstance(value, list):
        return any(contains_call_id(nested, call_id) for nested in value)
    return False


class QuietHTTPServer(ThreadingHTTPServer):
    daemon_threads = True

    def __init__(self, server_address, handler_class):
        super().__init__(server_address, handler_class)
        self.model_request_count = 0
        self.had_internal_error = False
        self.spawn_tool_seen = False
        self.first_tool_names: List[str] = []
        self.wait_tool_called = False
        self.spawn_tool_name: Optional[str] = None
        self.spawn_namespace: Optional[str] = None
        self.wait_tool_name: Optional[str] = None
        self.wait_namespace: Optional[str] = None
        self.request_lock = threading.Lock()

    def handle_error(self, request, client_address):
        self.had_internal_error = True


class LocalModelHandler(BaseHTTPRequestHandler):
    def log_message(self, format, *args):
        return

    def do_GET(self):
        if self.path not in {"/api/tags", "/v1/models"}:
            self.send_error(404)
            return
        body = json.dumps({
            "models": [{"name": MODEL_NAME, "id": MODEL_NAME}],
        }).encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_POST(self):
        content_length = int(self.headers.get("Content-Length", "0"))
        request_bytes = self.rfile.read(content_length)
        if not self.path.endswith("/responses"):
            self.send_error(404)
            return

        try:
            request = json.loads(request_bytes)
        except (UnicodeDecodeError, json.JSONDecodeError):
            self.send_error(400)
            return
        with self.server.request_lock:
            self.server.model_request_count += 1
            request_number = self.server.model_request_count

        spawn_tool_name = None
        spawn_namespace = None
        wait_tool_name = None
        wait_namespace = None
        for tool in request.get("tools", []):
            if not isinstance(tool, dict):
                continue
            tool_name = tool.get("name")
            if isinstance(tool_name, str) and tool_name.endswith("spawn_agent"):
                spawn_tool_name = tool_name
                continue
            if tool.get("type") != "namespace" or not isinstance(tool_name, str):
                continue
            nested_spawn = next(
                (
                    nested.get("name")
                    for nested in tool.get("tools", [])
                    if isinstance(nested, dict)
                    and nested.get("name") == "spawn_agent"
                ),
                None,
            )
            if nested_spawn is not None:
                spawn_tool_name = nested_spawn
                spawn_namespace = tool_name
            nested_wait = next(
                (
                    nested.get("name")
                    for nested in tool.get("tools", [])
                    if isinstance(nested, dict)
                    and nested.get("name") == "wait_agent"
                ),
                None,
            )
            if nested_wait is not None:
                wait_tool_name = nested_wait
                wait_namespace = tool_name
        with self.server.request_lock:
            if spawn_tool_name is not None:
                self.server.spawn_tool_name = spawn_tool_name
                self.server.spawn_namespace = spawn_namespace
            else:
                spawn_tool_name = self.server.spawn_tool_name
                spawn_namespace = self.server.spawn_namespace
            if wait_tool_name is not None:
                self.server.wait_tool_name = wait_tool_name
                self.server.wait_namespace = wait_namespace
            else:
                wait_tool_name = self.server.wait_tool_name
                wait_namespace = self.server.wait_namespace
        if request_number == 1:
            self.server.first_tool_names = []
            for tool in request.get("tools", []):
                if not isinstance(tool, dict):
                    continue
                tool_label = str(tool.get("name") or tool.get("type") or "unknown")
                self.server.first_tool_names.append(tool_label)
                self.server.first_tool_names.extend(
                    f"{tool_label}.{nested.get('name')}"
                    for nested in tool.get("tools", [])
                    if isinstance(nested, dict) and isinstance(nested.get("name"), str)
                )
        agent_target = spawned_agent_target(request)
        spawn_call_completed = contains_call_id(request.get("input", []), "call_agent_meong_spawn")
        with self.server.request_lock:
            should_wait_for_agent = (
                spawn_call_completed
                and wait_tool_name is not None
                and not self.server.wait_tool_called
            )
            if should_wait_for_agent:
                self.server.wait_tool_called = True

        if request_number == 1 and spawn_tool_name is not None:
            self.server.spawn_tool_seen = True
            output_item = {
                "id": "fc_agent_meong_spawn",
                "type": "function_call",
                "status": "completed",
                "name": spawn_tool_name,
                "call_id": "call_agent_meong_spawn",
                "arguments": json.dumps({
                    "message": "Return a short answer without using tools.",
                }),
            }
            if spawn_namespace is not None:
                output_item["namespace"] = spawn_namespace
        elif should_wait_for_agent:
            wait_arguments = {"timeout_ms": 10_000}
            if agent_target is not None:
                wait_arguments["targets"] = [agent_target]
            output_item = {
                "id": "fc_agent_meong_wait",
                "type": "function_call",
                "status": "completed",
                "name": wait_tool_name,
                "call_id": "call_agent_meong_wait",
                "arguments": json.dumps(wait_arguments),
            }
            if wait_namespace is not None:
                output_item["namespace"] = wait_namespace
        else:
            output_item = {
                "id": f"msg_agent_meong_acceptance_{request_number}",
                "type": "message",
                "status": "completed",
                "role": "assistant",
                "content": [{
                    "type": "output_text",
                    "annotations": [],
                    "logprobs": [],
                    "text": "ok",
                }],
            }
        usage = {
            "input_tokens": 1,
            "input_tokens_details": {"cached_tokens": 0},
            "output_tokens": 1,
            "output_tokens_details": {"reasoning_tokens": 0},
            "total_tokens": 2,
        }
        response = {
            "id": f"resp_agent_meong_acceptance_{request_number}",
            "object": "response",
            "created_at": 1,
            "status": "completed",
            "background": False,
            "error": None,
            "incomplete_details": None,
            "instructions": None,
            "max_output_tokens": None,
            "max_tool_calls": None,
            "model": MODEL_NAME,
            "output": [output_item],
            "parallel_tool_calls": True,
            "previous_response_id": None,
            "prompt_cache_key": None,
            "reasoning": {"effort": None, "summary": None},
            "safety_identifier": None,
            "service_tier": "default",
            "store": False,
            "temperature": 1.0,
            "text": {"format": {"type": "text"}, "verbosity": "medium"},
            "tool_choice": "auto",
            "tools": [],
            "top_logprobs": 0,
            "top_p": 1.0,
            "truncation": "disabled",
            "usage": usage,
            "user": None,
            "metadata": {},
        }
        events = [
            {
                "type": "response.output_item.done",
                "sequence_number": 1,
                "output_index": 0,
                "item": output_item,
            },
            {
                "type": "response.completed",
                "sequence_number": 2,
                "response": response,
            },
        ]
        body = b"".join(
            b"event: " + event["type"].encode("utf-8") + b"\n"
            + b"data: " + json.dumps(event).encode("utf-8") + b"\n\n"
            for event in events
        )
        self.send_response(200)
        self.send_header("Content-Type", "text/event-stream")
        self.send_header("Cache-Control", "no-cache")
        self.send_header("Connection", "close")
        self.end_headers()
        self.wfile.write(body)


class ObservationCapture:
    def __init__(self, path: pathlib.Path):
        self.path = path
        self.events: List[Dict[str, Any]] = []
        self.failure: Optional[str] = None
        self.ready = threading.Event()
        self.complete = threading.Event()
        self.stopping = threading.Event()
        self.server = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        self.server.bind(str(path))
        os.chmod(path, 0o600)
        self.server.listen(8)
        self.server.settimeout(0.1)
        self.thread = threading.Thread(target=self._run, daemon=True)

    def start(self):
        self.thread.start()
        self.ready.wait(timeout=1)

    def _run(self):
        self.ready.set()
        while not self.stopping.is_set() and len(self.events) < 64:
            try:
                connection, _ = self.server.accept()
            except socket.timeout:
                continue
            except OSError:
                break
            with connection:
                data = b""
                while len(data) < 65_536 and b"\n" not in data:
                    chunk = connection.recv(4_096)
                    if not chunk:
                        break
                    data += chunk
            try:
                for line in data.splitlines():
                    event = json.loads(line)
                    if not isinstance(event, dict):
                        self.failure = "adapter socket emitted a non-object observation"
                        break
                    self.events.append(event)
            except (UnicodeDecodeError, json.JSONDecodeError):
                self.failure = "adapter socket emitted invalid JSON"
                break
        self.complete.set()

    def wait_until_quiet(self, timeout: float):
        deadline = time.monotonic() + timeout
        previous_count = -1
        stable_polls = 0
        while time.monotonic() < deadline:
            current_count = len(self.events)
            if current_count == previous_count and current_count >= 5:
                stable_polls += 1
                if stable_polls >= 5:
                    return
            else:
                stable_polls = 0
            previous_count = current_count
            time.sleep(0.1)

    def close(self):
        self.stopping.set()
        self.thread.join(timeout=1)
        self.server.close()


def ensure(condition: bool, message: str):
    if not condition:
        raise AcceptanceFailure(message)


def validate_actual_hooks_list(
    root: pathlib.Path,
    codex_path: pathlib.Path,
    home: pathlib.Path,
    codex_home: pathlib.Path,
    environment: Dict[str, str],
):
    """Check the real Codex schema without persisting trust or raw metadata."""
    adapter_path = root / "adapters/codex_hook.py"
    specification = importlib.util.spec_from_file_location(
        "agent_meong_acceptance_adapter",
        adapter_path,
    )
    ensure(
        specification is not None and specification.loader is not None,
        "cannot load the adapter for hooks/list acceptance",
    )
    adapter = importlib.util.module_from_spec(specification)
    specification.loader.exec_module(adapter)

    previous_environment = dict(os.environ)
    try:
        os.environ.clear()
        os.environ.update(environment)
        payload = adapter._query_codex_runtime_hooks(
            codex_path,
            home=home,
            codex_home=codex_home,
        )
    finally:
        os.environ.clear()
        os.environ.update(previous_environment)

    ensure(payload is not None, "actual Codex app-server hooks/list was unavailable")
    result = adapter._classify_runtime_hooks(
        payload,
        adapter.user_paths(home=home, codex_home=codex_home),
    )
    ensure(
        result == {
            "runtimeStatus": "review_required",
            "runtimeProblemEvents": list(adapter.USER_HOOK_EVENTS),
        },
        "actual Codex hooks/list did not classify fresh user hooks as review_required",
    )


def isolated_environment(home: pathlib.Path, codex_home: pathlib.Path, socket_path: pathlib.Path):
    environment = {
        "PATH": os.environ.get("PATH", "/usr/bin:/bin"),
        "LANG": os.environ.get("LANG", "en_US.UTF-8"),
        "HOME": str(home),
        "CODEX_HOME": str(codex_home),
        "AGENT_MEONG_SOCKET": str(socket_path),
        "NO_PROXY": "127.0.0.1,localhost",
        "no_proxy": "127.0.0.1,localhost",
        "HTTP_PROXY": "http://127.0.0.1:9",
        "HTTPS_PROXY": "http://127.0.0.1:9",
        "ALL_PROXY": "http://127.0.0.1:9",
        "http_proxy": "http://127.0.0.1:9",
        "https_proxy": "http://127.0.0.1:9",
        "all_proxy": "http://127.0.0.1:9",
        "OTEL_SDK_DISABLED": "true",
    }
    return environment


def validate_observations(events: List[Dict[str, Any]]):
    ensure(
        len(events) >= 5,
        "expected main and subagent lifecycle observations; observed "
        + ", ".join(str(event.get("kind")) for event in events),
    )
    for event in events:
        ensure(set(event).issubset(ALLOWED_OBSERVATION_KEYS), "observation crossed privacy boundary")
        ensure(event.get("schemaVersion") == 0, "unexpected observation schema")
        ensure(event.get("source") == "openai.codex", "unexpected observation source")
        ensure(
            event.get("integrationVersion") == "dev.ailab.agent-meong/v5",
            "unexpected adapter integration version",
        )
        ensure(
            INSTANCE_PATTERN.fullmatch(str(event.get("integrationInstance") or ""))
            is not None,
            "invalid opaque integration instance",
        )
        for key in ("eventId", "sessionId", "actorId", "scopeId"):
            ensure(
                OPAQUE_ID_PATTERN.fullmatch(str(event.get(key) or "")) is not None,
                f"invalid opaque {key}",
            )
        if "parentActorId" in event:
            ensure(
                OPAQUE_ID_PATTERN.fullmatch(str(event["parentActorId"])) is not None,
                "invalid opaque parentActorId",
            )
    # Codex may retry the same lifecycle hook. Stable source-derived event IDs
    # let the app reducer deduplicate those deliveries. Accept only semantic
    # retries here; the same ID must never describe a different observation.
    unique_by_id: Dict[str, Dict[str, Any]] = {}
    for event in events:
        event_id = event["eventId"]
        previous = unique_by_id.get(event_id)
        if previous is None:
            unique_by_id[event_id] = event
            continue
        semantic_previous = {key: value for key, value in previous.items() if key != "occurredAt"}
        semantic_event = {key: value for key, value in event.items() if key != "occurredAt"}
        ensure(semantic_event == semantic_previous, "event ID collided across distinct observations")
    events = list(unique_by_id.values())
    lifecycle_summary = ", ".join(
        f"{event.get('kind')}{':child' if 'parentActorId' in event else ':root'}"
        for event in events
    )
    ensure(
        len(events) >= 5,
        f"expected five distinct lifecycle observations; observed {lifecycle_summary}",
    )
    main_started = next(
        (event for event in events if event.get("kind") == "turn.started"
         and "parentActorId" not in event),
        None,
    )
    main_stopped = next(
        (event for event in events if event.get("kind") == "turn.stopping"
         and "parentActorId" not in event),
        None,
    )
    child_started = next(
        (event for event in events if event.get("kind") == "agent.started"),
        None,
    )
    child_stopped = next(
        (event for event in events if event.get("kind") == "agent.finished"),
        None,
    )
    child_activity = next(
        (event for event in events if event.get("kind") in {
            "turn.started", "tool.started", "tool.finished", "approval.waiting"
        } and "parentActorId" in event),
        None,
    )
    ensure(
        main_started is not None and main_stopped is not None,
        f"root turn lifecycle missing; observed {lifecycle_summary}",
    )
    ensure(
        child_started is not None and child_stopped is not None,
        f"subagent lifecycle missing; observed {lifecycle_summary}",
    )
    ensure(
        child_activity is not None,
        f"subagent activity was not attributed to the child; observed {lifecycle_summary}",
    )
    ensure(main_started["actorId"] == main_stopped["actorId"], "root actor identity changed")
    ensure(main_started["scopeId"] == main_stopped["scopeId"], "root turn identity changed")
    ensure(child_started["actorId"] == child_stopped["actorId"], "child actor identity changed")
    ensure(child_activity["actorId"] == child_started["actorId"], "child activity split actors")
    ensure(
        child_started["parentActorId"] == main_started["actorId"]
        and child_activity["parentActorId"] == main_started["actorId"],
        "subagent parent identity did not point to the root actor",
    )
    ensure(
        SYNTHETIC_PROMPT not in json.dumps(events, sort_keys=True),
        "prompt text crossed the observation boundary",
    )


def main(root: pathlib.Path, codex_path: pathlib.Path):
    ensure_no_detected_external_hooks()
    with tempfile.TemporaryDirectory(prefix="agent-meong-codex-", dir="/tmp") as directory:
        temporary = pathlib.Path(directory)
        home = temporary / "home"
        codex_home = temporary / "codex-home"
        work = temporary / "work"
        socket_path = temporary / "events.sock"
        home.mkdir()
        codex_home.mkdir()
        work.mkdir()

        capture = ObservationCapture(socket_path)
        model_server = QuietHTTPServer(("127.0.0.1", 0), LocalModelHandler)
        model_thread = threading.Thread(target=model_server.serve_forever, daemon=True)
        capture.start()
        model_thread.start()
        environment = isolated_environment(home, codex_home, socket_path)
        environment["CODEX_OSS_BASE_URL"] = (
            f"http://127.0.0.1:{model_server.server_port}/v1"
        )

        try:
            install = subprocess.run(
                ["/bin/bash", str(root / "scripts/install-codex-hook")],
                env=environment,
                stdin=subprocess.DEVNULL,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                timeout=10,
                check=False,
            )
            ensure(install.returncode == 0, "isolated hook installation failed")
            validate_actual_hooks_list(
                root,
                codex_path,
                home,
                codex_home,
                environment,
            )

            command_prefix = [
                str(codex_path),
                "exec",
                "--ephemeral",
                "--ignore-user-config",
                "--enable",
                "hooks",
                "--disable",
                "plugins",
                "--sandbox",
                "read-only",
                "-c",
                'approval_policy="never"',
                "--oss",
                "--local-provider",
                "ollama",
                "-m",
                MODEL_NAME,
                "--skip-git-repo-check",
                "-C",
                str(work),
            ]
            try:
                untrusted = subprocess.run(
                    [*command_prefix, SYNTHETIC_PROMPT],
                    env=environment,
                    stdin=subprocess.DEVNULL,
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                    timeout=20,
                    check=False,
                )
            except subprocess.TimeoutExpired as error:
                raise AcceptanceFailure("Codex CLI trust-gating probe timed out") from error

            ensure(untrusted.returncode == 0, "Codex CLI trust-gating probe failed")
            # The process does not return until its turn-scoped hooks have
            # either run or been skipped. A short grace period also covers the
            # thread-scoped subagent hook before we inspect the socket.
            time.sleep(0.25)
            ensure(capture.failure is None, capture.failure or "socket capture failed")
            ensure(
                model_server.model_request_count >= 1,
                "Codex CLI trust-gating probe did not reach the local model",
            )
            ensure(
                not capture.events,
                "untrusted user hooks ran before explicit trust: "
                + ", ".join(str(event.get("kind")) for event in capture.events),
            )
            ensure(
                not model_server.had_internal_error,
                "local model server failed during trust-gating probe",
            )

            # Reset only the deterministic local-model fixture. The isolated
            # Codex home intentionally remains unchanged so the next phase
            # proves the same still-untrusted definitions run only with the
            # explicit automation-only bypass.
            with model_server.request_lock:
                model_server.model_request_count = 0
                model_server.spawn_tool_seen = False
                model_server.wait_tool_called = False
                model_server.first_tool_names = []
                model_server.had_internal_error = False

            try:
                completed = subprocess.run(
                    [
                        *command_prefix,
                        "--dangerously-bypass-hook-trust",
                        SYNTHETIC_PROMPT,
                    ],
                    env=environment,
                    stdin=subprocess.DEVNULL,
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                    timeout=20,
                    check=False,
                )
            except subprocess.TimeoutExpired as error:
                raise AcceptanceFailure("Codex CLI lifecycle phase timed out") from error

            ensure(completed.returncode == 0, "Codex CLI lifecycle phase failed")
            capture.wait_until_quiet(timeout=5)
            ensure(capture.failure is None, capture.failure or "socket capture failed")
            ensure(
                model_server.spawn_tool_seen,
                "Codex did not expose spawn_agent; tools: "
                + ", ".join(model_server.first_tool_names),
            )
            try:
                validate_observations(capture.events)
            except AcceptanceFailure as error:
                raise AcceptanceFailure(
                    f"{error}; exposed tools: "
                    + ", ".join(model_server.first_tool_names)
                ) from error
            ensure(model_server.model_request_count >= 2, "subagent did not reach the local model")
            ensure(not model_server.had_internal_error, "local model server failed")
        finally:
            capture.close()
            model_server.shutdown()
            model_server.server_close()
            model_thread.join(timeout=1)


try:
    main(pathlib.Path(sys.argv[1]), pathlib.Path(sys.argv[2]))
except AcceptanceFailure as error:
    print(f"agent-meong Codex CLI acceptance failed: {error}", file=sys.stderr)
    raise SystemExit(1)
except (OSError, subprocess.SubprocessError) as error:
    print(
        "agent-meong Codex CLI acceptance failed: "
        f"local harness {type(error).__name__}",
        file=sys.stderr,
    )
    raise SystemExit(1)

print(
    "agent-meong Codex CLI acceptance: "
    "actual hooks/list reported review_required; untrusted hooks were skipped; "
    "bypassed root and subagent lifecycle reached the adapter socket"
)
