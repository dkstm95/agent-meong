# A bootout failure must retain both the validated plist and app so launchd can
# never hold a job whose executable has been deleted.
BOOTOUT_INSTALL_ROOT="$CHECK_ROOT/bootout-install"
BOOTOUT_APP="$BOOTOUT_INSTALL_ROOT/AgentMeong.app"
BOOTOUT_LAUNCH_AGENTS_DIR="$CHECK_ROOT/bootout-launch-agents"
BOOTOUT_LOGIN_ITEM="$BOOTOUT_LAUNCH_AGENTS_DIR/$LOGIN_ITEM_LABEL.plist"
BOOTOUT_LAUNCHCTL_STATE="$CHECK_ROOT/bootout-launchctl-state"
BOOTOUT_LAUNCHCTL_LOG="$CHECK_ROOT/bootout-launchctl.log"
BOOTOUT_PREFERENCES_DOMAIN="dev.ailab.agent-meong.bootout.$$"
printf '%s\n' unloaded >"$BOOTOUT_LAUNCHCTL_STATE"
env HOME="$CHECK_HOME" \
    AGENT_MEONG_INSTALL_DIR="$BOOTOUT_INSTALL_ROOT" \
    AGENT_MEONG_TEST_LAUNCH_AGENTS_DIR="$BOOTOUT_LAUNCH_AGENTS_DIR" \
    AGENT_MEONG_TEST_LAUNCHCTL_STATE_FILE="$BOOTOUT_LAUNCHCTL_STATE" \
    AGENT_MEONG_TEST_LAUNCHCTL_LOG="$BOOTOUT_LAUNCHCTL_LOG" \
    AGENT_MEONG_SKIP_LAUNCH=1 \
    AGENT_MEONG_KEEP_BUILD_ARTIFACTS=1 \
    AGENT_MEONG_TEST_PACKAGE_APP="$REPLACEMENT_APP" \
    /bin/bash "$ROOT/scripts/install-app" >/dev/null
BOOTOUT_LOGIN_ITEM_FINGERPRINT=$(login_item_fingerprint "$BOOTOUT_LOGIN_ITEM")
if env HOME="$CHECK_HOME" \
    CODEX_HOME="$DEFAULT_CODEX_HOME" \
    AGENT_MEONG_INSTALL_DIR="$BOOTOUT_INSTALL_ROOT" \
    AGENT_MEONG_TEST_LAUNCH_AGENTS_DIR="$BOOTOUT_LAUNCH_AGENTS_DIR" \
    AGENT_MEONG_TEST_LAUNCHCTL_STATE_FILE="$BOOTOUT_LAUNCHCTL_STATE" \
    AGENT_MEONG_TEST_LAUNCHCTL_LOG="$BOOTOUT_LAUNCHCTL_LOG" \
    AGENT_MEONG_TEST_LAUNCHCTL_FAIL_BOOTOUT=1 \
    AGENT_MEONG_PREFERENCES_DOMAIN="$BOOTOUT_PREFERENCES_DOMAIN" \
    /bin/bash "$ROOT/scripts/uninstall-app" >/dev/null 2>"$CHECK_ROOT/bootout-failure.stderr"
then
    echo "uninstall-app accepted a launchctl bootout failure" >&2
    exit 1
fi
test -d "$BOOTOUT_APP"
test "$(login_item_fingerprint "$BOOTOUT_LOGIN_ITEM")" \
    = "$BOOTOUT_LOGIN_ITEM_FINGERPRINT"
test "$(/bin/cat "$BOOTOUT_LAUNCHCTL_STATE")" = "loaded"
/usr/bin/grep -F 'launchd cleanup failed' "$CHECK_ROOT/bootout-failure.stderr" >/dev/null
env HOME="$CHECK_HOME" \
    CODEX_HOME="$DEFAULT_CODEX_HOME" \
    AGENT_MEONG_INSTALL_DIR="$BOOTOUT_INSTALL_ROOT" \
    AGENT_MEONG_TEST_LAUNCH_AGENTS_DIR="$BOOTOUT_LAUNCH_AGENTS_DIR" \
    AGENT_MEONG_TEST_LAUNCHCTL_STATE_FILE="$BOOTOUT_LAUNCHCTL_STATE" \
    AGENT_MEONG_TEST_LAUNCHCTL_LOG="$BOOTOUT_LAUNCHCTL_LOG" \
    AGENT_MEONG_PREFERENCES_DOMAIN="$BOOTOUT_PREFERENCES_DOMAIN" \
    /bin/bash "$ROOT/scripts/uninstall-app" >/dev/null
test ! -e "$BOOTOUT_APP"
test ! -e "$BOOTOUT_LOGIN_ITEM"
test "$(/bin/cat "$BOOTOUT_LAUNCHCTL_STATE")" = "unloaded"

# Unsafe or wrongly-owned LaunchAgents directories fail before either bundle
# replacement or removal. The expected-uid seam makes the ownership branch
# deterministic without requiring privileged chown in the check.
DIRECTORY_INSTALL_ROOT="$CHECK_ROOT/directory-guard-install"
DIRECTORY_APP="$DIRECTORY_INSTALL_ROOT/AgentMeong.app"
DIRECTORY_LAUNCH_AGENTS_DIR="$CHECK_ROOT/directory-guard-launch-agents"
DIRECTORY_LAUNCHCTL_STATE="$CHECK_ROOT/directory-launchctl-state"
DIRECTORY_LAUNCHCTL_LOG="$CHECK_ROOT/directory-launchctl.log"
DIRECTORY_PREFERENCES_DOMAIN="dev.ailab.agent-meong.directory.$$"
make_version_app "$DIRECTORY_APP" directory-guard-version
/bin/mkdir -p "$DIRECTORY_LAUNCH_AGENTS_DIR"
/bin/chmod 0777 "$DIRECTORY_LAUNCH_AGENTS_DIR"
printf '%s\n' unloaded >"$DIRECTORY_LAUNCHCTL_STATE"
if env HOME="$CHECK_HOME" \
    AGENT_MEONG_INSTALL_DIR="$DIRECTORY_INSTALL_ROOT" \
    AGENT_MEONG_TEST_LAUNCH_AGENTS_DIR="$DIRECTORY_LAUNCH_AGENTS_DIR" \
    AGENT_MEONG_TEST_LAUNCHCTL_STATE_FILE="$DIRECTORY_LAUNCHCTL_STATE" \
    AGENT_MEONG_TEST_LAUNCHCTL_LOG="$DIRECTORY_LAUNCHCTL_LOG" \
    AGENT_MEONG_SKIP_LAUNCH=1 \
    AGENT_MEONG_KEEP_BUILD_ARTIFACTS=1 \
    AGENT_MEONG_TEST_PACKAGE_APP="$FAILED_REPLACEMENT_APP" \
    /bin/bash "$ROOT/scripts/install-app" >/dev/null 2>"$CHECK_ROOT/directory-mode.stderr"
then
    echo "install-app accepted a group/world-writable LaunchAgents directory" >&2
    exit 1
fi
/usr/bin/grep -F 'directory-guard-version' "$DIRECTORY_APP/Contents/MacOS/AgentMeong" >/dev/null
if env HOME="$CHECK_HOME" \
    CODEX_HOME="$DEFAULT_CODEX_HOME" \
    AGENT_MEONG_INSTALL_DIR="$DIRECTORY_INSTALL_ROOT" \
    AGENT_MEONG_TEST_LAUNCH_AGENTS_DIR="$DIRECTORY_LAUNCH_AGENTS_DIR" \
    AGENT_MEONG_TEST_LAUNCHCTL_STATE_FILE="$DIRECTORY_LAUNCHCTL_STATE" \
    AGENT_MEONG_TEST_LAUNCHCTL_LOG="$DIRECTORY_LAUNCHCTL_LOG" \
    AGENT_MEONG_PREFERENCES_DOMAIN="$DIRECTORY_PREFERENCES_DOMAIN" \
    /bin/bash "$ROOT/scripts/uninstall-app" >/dev/null 2>"$CHECK_ROOT/directory-uninstall.stderr"
then
    echo "uninstall-app accepted a group/world-writable LaunchAgents directory" >&2
    exit 1
fi
test -d "$DIRECTORY_APP"
/bin/chmod 0700 "$DIRECTORY_LAUNCH_AGENTS_DIR"
WRONG_EXPECTED_UID="$(( $(/usr/bin/id -u) + 1 ))"
if env HOME="$CHECK_HOME" \
    AGENT_MEONG_INSTALL_DIR="$DIRECTORY_INSTALL_ROOT" \
    AGENT_MEONG_TEST_LAUNCH_AGENTS_DIR="$DIRECTORY_LAUNCH_AGENTS_DIR" \
    AGENT_MEONG_TEST_LAUNCHCTL_STATE_FILE="$DIRECTORY_LAUNCHCTL_STATE" \
    AGENT_MEONG_TEST_LAUNCHCTL_LOG="$DIRECTORY_LAUNCHCTL_LOG" \
    AGENT_MEONG_TEST_EXPECTED_UID="$WRONG_EXPECTED_UID" \
    AGENT_MEONG_SKIP_LAUNCH=1 \
    AGENT_MEONG_KEEP_BUILD_ARTIFACTS=1 \
    AGENT_MEONG_TEST_PACKAGE_APP="$FAILED_REPLACEMENT_APP" \
    /bin/bash "$ROOT/scripts/install-app" >/dev/null 2>"$CHECK_ROOT/directory-owner.stderr"
then
    echo "install-app accepted a LaunchAgents directory owned by an unexpected uid" >&2
    exit 1
fi
/usr/bin/grep -F 'directory-guard-version' "$DIRECTORY_APP/Contents/MacOS/AgentMeong" >/dev/null

make_version_app "$APP" login-item-guard-version
/bin/mkdir -p "$LAUNCH_AGENTS_DIR"
LOGIN_ITEM_TARGET="$CHECK_ROOT/unexpected-login-item-target"
printf '%s\n' keep-me >"$LOGIN_ITEM_TARGET"
ln -s "$LOGIN_ITEM_TARGET" "$LOGIN_ITEM"
if env HOME="$CHECK_HOME" \
    AGENT_MEONG_INSTALL_DIR="$INSTALL_ROOT" \
    AGENT_MEONG_SKIP_LAUNCH=1 \
    AGENT_MEONG_KEEP_BUILD_ARTIFACTS=1 \
    AGENT_MEONG_TEST_PACKAGE_APP="$FAILED_REPLACEMENT_APP" \
    /bin/bash "$ROOT/scripts/install-app" >/dev/null 2>"$CHECK_ROOT/login-symlink.stderr"
then
    echo "install-app accepted a symbolic-link login item" >&2
    exit 1
fi
test -L "$LOGIN_ITEM"
/usr/bin/grep -F 'unexpected login item' "$CHECK_ROOT/login-symlink.stderr" >/dev/null
/usr/bin/grep -F 'login-item-guard-version' "$APP/Contents/MacOS/AgentMeong" >/dev/null
/bin/rm -f "$LOGIN_ITEM" "$LOGIN_ITEM_TARGET"

cp "$ROOT/macos/Resources/Info.plist" "$LOGIN_ITEM"
chmod 600 "$LOGIN_ITEM"
if env HOME="$CHECK_HOME" \
    CODEX_HOME="$DEFAULT_CODEX_HOME" \
    AGENT_MEONG_INSTALL_DIR="$INSTALL_ROOT" \
    AGENT_MEONG_PREFERENCES_DOMAIN="$PREFERENCES_DOMAIN" \
    /bin/bash "$ROOT/scripts/uninstall-app" >/dev/null 2>"$CHECK_ROOT/unexpected-login.stderr"
then
    echo "uninstall-app accepted an unexpected login item definition" >&2
    exit 1
fi
test -d "$APP"
test -f "$LOGIN_ITEM"
/usr/bin/grep -F 'login item validation failed' "$CHECK_ROOT/unexpected-login.stderr" >/dev/null
/bin/rm -f "$LOGIN_ITEM"

make_version_app "$APP" symlink-guard-version
SUPPORT_TARGET="$CHECK_ROOT/support-target"
mkdir -p "$SUPPORT_TARGET" "$(dirname "$SUPPORT_ROOT")"
ln -s "$SUPPORT_TARGET" "$SUPPORT_ROOT"
if env HOME="$CHECK_HOME" \
    CODEX_HOME="$DEFAULT_CODEX_HOME" \
    AGENT_MEONG_INSTALL_DIR="$INSTALL_ROOT" \
    AGENT_MEONG_PREFERENCES_DOMAIN="$PREFERENCES_DOMAIN" \
    /bin/bash "$ROOT/scripts/uninstall-app" >/dev/null 2>"$CHECK_ROOT/support-symlink.stderr"
then
    echo "uninstall-app accepted symbolic-link application support" >&2
    exit 1
fi
test -d "$APP"
/bin/rm -f "$SUPPORT_ROOT"
mkdir -p "$SUPPORT_ROOT"
ln -s "$SUPPORT_TARGET" "$SUPPORT_ROOT/codex-hooks"
if env HOME="$CHECK_HOME" \
    CODEX_HOME="$DEFAULT_CODEX_HOME" \
    AGENT_MEONG_INSTALL_DIR="$INSTALL_ROOT" \
    AGENT_MEONG_PREFERENCES_DOMAIN="$PREFERENCES_DOMAIN" \
    /bin/bash "$ROOT/scripts/uninstall-app" >/dev/null 2>"$CHECK_ROOT/adapter-symlink.stderr"
then
    echo "uninstall-app accepted a symbolic-link adapter directory" >&2
    exit 1
fi
test -d "$APP"
/bin/rm -rf "$APP"
/bin/rm -f "$SUPPORT_ROOT/codex-hooks"
/bin/rmdir "$SUPPORT_ROOT"

make_version_app "$APP" unknown-support-version
mkdir -p "$SUPPORT_ROOT"
printf '%s\n' keep-me >"$SUPPORT_ROOT/unrecognized-data"
if env HOME="$CHECK_HOME" \
    CODEX_HOME="$DEFAULT_CODEX_HOME" \
    AGENT_MEONG_INSTALL_DIR="$INSTALL_ROOT" \
    AGENT_MEONG_PREFERENCES_DOMAIN="$PREFERENCES_DOMAIN" \
    /bin/bash "$ROOT/scripts/uninstall-app" >/dev/null 2>"$CHECK_ROOT/unknown-support.stderr"
then
    echo "uninstall-app reported success while unknown support data remained" >&2
    exit 1
fi
test ! -e "$APP"
test -f "$SUPPORT_ROOT/unrecognized-data"
/usr/bin/grep -F 'Uninstall is incomplete' "$CHECK_ROOT/unknown-support.stderr" >/dev/null
/bin/rm -f "$SUPPORT_ROOT/unrecognized-data"
/bin/rmdir "$SUPPORT_ROOT"

make_version_app "$APP" unsafe-socket-version
SOCKET_TARGET="$CHECK_ROOT/socket-target"
printf '%s\n' keep-me >"$SOCKET_TARGET"
ln -s "$SOCKET_TARGET" "$SOCKET_PATH"
if env HOME="$CHECK_HOME" \
    CODEX_HOME="$DEFAULT_CODEX_HOME" \
    AGENT_MEONG_INSTALL_DIR="$INSTALL_ROOT" \
    AGENT_MEONG_SOCKET="$SOCKET_PATH" \
    AGENT_MEONG_PREFERENCES_DOMAIN="$PREFERENCES_DOMAIN" \
    /bin/bash "$ROOT/scripts/uninstall-app" >/dev/null 2>"$CHECK_ROOT/unsafe-socket.stderr"
then
    echo "uninstall-app reported success while an unsafe socket link remained" >&2
    exit 1
fi
test ! -e "$APP"
test -L "$SOCKET_PATH"
/usr/bin/grep -F 'Uninstall is incomplete' "$CHECK_ROOT/unsafe-socket.stderr" >/dev/null
/bin/rm -f "$SOCKET_PATH" "$SOCKET_TARGET"

echo "agent-meong app lifecycle: fail-closed uninstall, ordered cleanup, and safe replacement passed"
