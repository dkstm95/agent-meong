#!/bin/sh

set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
CACHE="$ROOT/macos/.build/local-cache"

mkdir -p "$CACHE/clang" "$CACHE/swiftpm" "$CACHE/config" "$CACHE/security"

cd "$ROOT/macos"
export CLANG_MODULE_CACHE_PATH="$CACHE/clang"
export SWIFTPM_MODULECACHE_OVERRIDE="$CACHE/swiftpm"

for script in "$ROOT"/scripts/*; do
    sh -n "$script"
done
/bin/bash "$ROOT/scripts/check-codex-hook"
/bin/bash "$ROOT/scripts/check-app-lifecycle"
/usr/bin/python3 -m unittest discover -s "$ROOT/adapters" -p 'test_*.py'
swift run --disable-sandbox \
    --cache-path "$CACHE/swiftpm" \
    --config-path "$CACHE/config" \
    --security-path "$CACHE/security" \
    AgentMeongCoreChecks
swift build --disable-sandbox \
    --cache-path "$CACHE/swiftpm" \
    --config-path "$CACHE/config" \
    --security-path "$CACHE/security" \
    --product AgentMeong
