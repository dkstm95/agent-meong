#!/bin/sh

set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
if result=$(/usr/bin/python3 "$ROOT/adapters/codex_hook.py" --install); then
    :
else
    status=$?
    exit "$status"
fi
if ! printf '%s\n' "$result" | grep -F '"status": "installed"' >/dev/null; then
    printf 'Could not enable the Codex connection / Codex 사용자 연결을 활성화하지 못했습니다: %s\n' "$result" >&2
    exit 1
fi
echo "Installed the Codex user connection. / Codex 사용자 연결을 설치했습니다."
echo "Fully quit and reopen running Codex App and CLI instances so they load the changed hooks."
echo "실행 중인 Codex App과 CLI를 완전히 종료하고 다시 열어 변경된 hook을 불러오세요."
echo "In the newly opened Codex CLI, open /hooks and review and trust the User config lifecycle events and commands."
echo "새로 연 Codex CLI에서 /hooks를 열어 User config의 lifecycle event와 command를 검토하고 신뢰하세요."
