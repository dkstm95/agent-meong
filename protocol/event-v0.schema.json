{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-meong.local/schemas/event-v0.schema.json",
  "title": "Agent Meong Activity Observation v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "eventId",
    "source",
    "sessionId",
    "actorId",
    "occurredAt",
    "kind"
  ],
  "properties": {
    "schemaVersion": { "const": 0 },
    "eventId": {
      "type": "string",
      "minLength": 32,
      "maxLength": 32,
      "pattern": "^[0-9a-f]{32}$"
    },
    "source": {
      "type": "string",
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9-]{0,15}(\\.[a-z][a-z0-9-]{0,15}){1,3}$"
    },
    "sessionId": {
      "type": "string",
      "minLength": 32,
      "maxLength": 32,
      "pattern": "^[0-9a-f]{32}$"
    },
    "actorId": {
      "type": "string",
      "minLength": 32,
      "maxLength": 32,
      "pattern": "^[0-9a-f]{32}$"
    },
    "parentActorId": {
      "type": "string",
      "minLength": 32,
      "maxLength": 32,
      "pattern": "^[0-9a-f]{32}$"
    },
    "scopeId": {
      "type": "string",
      "minLength": 32,
      "maxLength": 32,
      "pattern": "^[0-9a-f]{32}$"
    },
    "occurredAt": { "type": "string", "format": "date-time" },
    "kind": {
      "enum": [
        "session.opened",
        "turn.started",
        "tool.started",
        "tool.finished",
        "approval.waiting",
        "agent.started",
        "agent.finished",
        "turn.stopping",
        "heartbeat"
      ]
    },
    "integrationVersion": {
      "type": "string",
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9-]{0,15}(\\.[a-z][a-z0-9-]{0,15}){1,3}/v[1-9][0-9]{0,8}$"
    },
    "integrationInstance": {
      "type": "string",
      "maxLength": 64,
      "pattern": "^(unscoped|[0-9a-f]{24,64})$"
    },
    "toolCategory": {
      "enum": ["shell", "edit", "search", "browser", "other"]
    },
    "outcome": {
      "enum": ["success", "failure", "cancelled"]
    }
  }
}
